---
import SearchBar from "@/layouts/helpers/SearchBar";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { BiSearchAlt } from "react-icons/bi";

// Retrieve all articles
const posts = await getSinglePage("posts");

// List of items to search in
const searchList = posts.map((item) => ({
  slug: item.id,
  data: item.data,
  content: item.body,
}));

// SEO 2026 — canonical URL & logo
const base_url = (config?.site?.base_url || "").replace(/\/$/, "");
const canonicalUrl = `${base_url}/search`;
const siteLogo  = `${base_url}/images/logo.png`;
const siteTitle = config?.site?.title || "WalaKatha";

// 🚀 SEARCH PAGE SCHEMA 2026 — SearchAction + WebSite sameAs
const searchPageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${base_url}/#website`,
      "url": base_url,
      "name": siteTitle,
      "inLanguage": "si",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${canonicalUrl}?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "SearchResultsPage",
      "@id": `${canonicalUrl}/#searchpage`,
      "url": canonicalUrl,
      "name": `කතා සෙවීම | Search Sinhala Wal Katha - ${siteTitle}`,
      "description": "ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක් හෝ වැල කතාවක් නම හෝ අකුරු මඟින් පහසුවෙන් සොයා ගන්න.",
      "inLanguage": "si",
      "isPartOf": { "@id": `${base_url}/#website` },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "මුල් පිටුව",
            "item": base_url
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "කතා සෙවීම",
            "item": canonicalUrl
          }
        ]
      }
    }
  ]
};
---

<Base
  title={`කතා සෙවීම | Search Sinhala Wal Katha & Wela Stories - ${siteTitle}`}
  meta_title={`කතා සෙවීම | Search Sinhala Wal Katha & Wela Stories - ${siteTitle}`}
  description="ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක්, වැල කතාවක් හෝ කෙටි කතාවක් නම භාවිත කරමින් ක්ෂණිකව සොයා ගන්න."
  canonical={canonicalUrl}
  image={siteLogo}
>

  {/* ── JSON-LD ── */}
  <script type="application/ld+json" set:html={JSON.stringify(searchPageSchema)} />

  {/* ── HEAD SLOT — OG / Twitter / Robots ── */}
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    {/* Open Graph */}
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="si_LK" />
    <meta property="og:site_name"   content={siteTitle} />
    <meta property="og:title"       content={`කතා සෙවීම | Search Sinhala Wal Katha - ${siteTitle}`} />
    <meta property="og:description" content="ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක් නම භාවිත කරමින් ක්ෂණිකව සොයා ගන්න." />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:image"       content={siteLogo} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content={`${siteTitle} Search`} />

    {/* Twitter / X */}
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={`කතා සෙවීම | Search Sinhala Wal Katha - ${siteTitle}`} />
    <meta name="twitter:description" content="ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක් නම භාවිත කරමින් ක්ෂණිකව සොයා ගන්න." />
    <meta name="twitter:image"       content={siteLogo} />

    {/* Sinhala / language */}
    <meta http-equiv="content-language" content="si" />
    <link rel="alternate" hreflang="si" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
  </Fragment>

  {/* ── STYLES ──
      ✅ FIX: !important හෝ :global() input overrides නෑ
      Container / hero styles පමණක් — React controlled input touch නොකෙරේ
  ── */}
  <style>
    .search-hero-container {
      background: linear-gradient(135deg, #0d0d0d 0%, #080808 100%);
      border: 1px solid #1a1a1a;
      border-radius: 20px;
      padding: 2.5rem 2rem;
      box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.7);
      position: relative;
      overflow: hidden;
      margin-bottom: 2.5rem;
    }

    .search-hero-container::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(1, 173, 159, 0.05) 0%, transparent 70%);
      pointer-events: none;
    }

    /* ✅ SEO-safe visually hidden H1 — Google safe pattern */
    .seo-visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  {/* ── MAIN ── */}
  <main class="section pt-6 pb-12 min-h-screen bg-[#050505] antialiased">
    <div class="container max-w-4xl">

      {/* SEO H1 — bots only */}
      <div class="seo-visually-hidden">
        <h1>සිංහල වල් කතා සෙවුම් | Search Sinhala Wal Katha Stories</h1>
        <p>WalaKatha වෙබ් අඩවියේ ඇති සියලුම වැල කතා සහ කෙටි කතා මෙතැනින් සොයා ගන්න.</p>
      </div>

      {/* HERO SEARCH BOX */}
      <div class="search-hero-container text-center">
        <div class="flex justify-center items-center mb-3 text-emerald-400">
          <BiSearchAlt className="h-8 w-8 mr-2 animate-pulse" />
          <span class="text-xs md:text-sm font-bold tracking-widest uppercase text-emerald-400/80">
            WalaKatha Instant Finder
          </span>
        </div>

        <h2 class="text-xl md:text-2xl font-black text-white mb-2">
          ඔබට අවශ්‍ය ඕනෑම කතාවක් මෙතැනින් සොයන්න
        </h2>
        <p class="text-xs md:text-sm text-slate-400 mb-6 max-w-lg mx-auto">
          කතාවේ නම, ලේඛකයා හෝ ඔබට මතක ඕනෑම වචනයක් පහත පෙට්ටියේ Type කරන්න.
        </p>

        {/* ✅ SearchBar — client:load, no wrapper CSS that touches input */}
        <div class="text-left relative">
          {/* ✅ ROOT FIX: transition:persist — ClientRouter (View Transitions)
               navigation/morph event වලදී React island unmount/remount වීම
               නවතී. නැතිනම් state (inputVal) reset වී input "disappear" වෙනවා
               type කරද්දී (3rd char → re-render → astro:page-load → reset). */}
          <SearchBar client:load searchList={searchList} transition:persist="search-bar" />
        </div>
      </div>

    </div>
  </main>

</Base>
