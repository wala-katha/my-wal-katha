---
import { humanize } from "@/lib/utils/textConverter";

const demoSlides = [
  {
    id: "thaththa-duwa-wal-katha/",
    title: "thaththa duwa wal katha - තාත්තයි දුවයි වල් කතා",
    image: "/images/slider/slide-1.webp",
    category: "Wal Katha"
  },
  {
    id: "methsala-akka-wal-katha/",
    title: "methsala akka wal katha - මෙත්සලා අක්කා වල් කතා",
    image: "/images/slider/slide-2.webp",
    category: "Wela Katha"
  },
  {
    id: "new-wal-katha",
    title: "තේශය ලබා - New Wal Katha",
    image: "/images/slider/slide-3.webp",
    category: "wala katha"
  },
  {
    id: "popular-wal-katha",
    title: "නවතම සිංහල වල් කතා එකතුව - Popular Stories",
    image: "/images/slider/slide-4.webp",
    category: "True Story"
  }
];
---

<div
  class="relative w-full overflow-hidden rounded-xl bg-[#010203] mb-8 border border-white/10"
  id="featured-slider"
>
  <!-- Slides -->
  <div
    class="flex transition-transform duration-500 ease-in-out will-change-transform"
    id="slider-track"
  >
    {demoSlides.map((slide, index) => (
      <div class="w-full flex-shrink-0 relative">
        <a
          href={`/blog/${slide.id}/`}
          class="block w-full h-full group"
          aria-label={`Read story: ${slide.title}`}
        >
          <div class="relative w-full aspect-[16/9] sm:aspect-[21/9] overflow-hidden bg-[#010203]">
            <img
              src={slide.image}
              alt={slide.title}
              width="900"
              height="506"
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={index === 0 ? "high" : "low"}
              class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>

          <div class="absolute bottom-3 left-4 z-10">
            <span class="bg-[#FFCC00] text-[#010203] px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}
  </div>

  <!-- Dots -->
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-20">
    {demoSlides.map((_, index) => (
      <button
        class="w-2 h-2 rounded-full bg-white/40 transition-all duration-300 dot"
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      />
    ))}
  </div>
</div>

<script is:inline>
  const SLIDE_COUNT = 4;
  const INTERVAL = 4000;

  function initFeaturedSlider() {
    const track = document.getElementById("slider-track");
    const root = document.getElementById("featured-slider");
    const dots = Array.from(document.querySelectorAll(".dot"));

    if (!track || !root || dots.length === 0) return;

    let index = 0;
    let timer = null;

    function update(i) {
      index = i;

      // move slider (clean % based)
      track.style.transform = `translateX(-${i * 100}%)`;

      // dots update
      dots.forEach((dot, d) => {
        dot.classList.toggle("bg-[#01AD9F]", d === i);
        dot.classList.toggle("scale-125", d === i);
        dot.classList.toggle("bg-white/40", d !== i);
      });
    }

    function next() {
      update((index + 1) % SLIDE_COUNT);
    }

    function start() {
      stop();
      timer = setInterval(next, INTERVAL);
    }

    function stop() {
      if (timer) clearInterval(timer);
    }

    // dot click
    dots.forEach((dot) => {
      dot.addEventListener("click", (e) => {
        const i = Number(dot.dataset.index);
        update(i);
        start();
      });
    });

    // touch support (optimized)
    let startX = 0;

    root.addEventListener(
      "touchstart",
      (e) => {
        startX = e.touches[0].clientX;
        stop();
      },
      { passive: true }
    );

    root.addEventListener(
      "touchend",
      (e) => {
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;

        if (Math.abs(diff) > 50) {
          update(diff > 0 ? (index + 1) % SLIDE_COUNT : (index - 1 + SLIDE_COUNT) % SLIDE_COUNT);
        }

        start();
      },
      { passive: true }
    );

    // pause on hover
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    // start
    update(0);
    start();

    // cleanup for Astro navigation
    document.addEventListener("astro:before-swap", () => stop());
  }

  document.addEventListener("astro:page-load", initFeaturedSlider);
</script>
