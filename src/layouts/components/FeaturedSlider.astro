---
import { humanize } from "@/lib/utils/textConverter";  
  
const demoSlides = [  
  {  
    id: "thaththa-duwa-wal-katha/",  
    title: "thaththa duwa wal katha - තාත්තයි දුවයි වල් කතා",  
    image: "/images/slider/slide-1.webp",  
    category: "Wal Katha"  
  },  
  {  
    id: "methsala-akka-wal-katha/",  
    title: "methsala akka wal katha - මෙත්සලා අක්කා වල් කතා",  
    image: "/images/slider/slide-2.webp",  
    category: "Wela Katha"  
  },  
  {  
    id: "nandage-duwa-wal-katha/",  
    title: "Nandage duwa wal katha - නැන්දගේ දුව වල් කතා",  
    image: "/images/slider/slide-3.webp",  
    category: "wala katha"  
  },  
  {  
    id: "gedara-driver-wal-katha/",  
    title: "Gedara driver wal katha - ගෙදර ඩ්‍රයිවර් වල් කතා",  
    image: "/images/slider/slide-4.webp",  
    category: "True Story"  
  }  
];  
---  
  
<div class="relative w-full overflow-hidden rounded-xl bg-[#010203] mb-8 border border-white/10" id="astro-featured-slider">  
  <div class="flex transition-transform duration-500 ease-in-out will-change-transform" id="slider-wrapper" style="width: 400%;">  
    {demoSlides.map((slide, index) => (  
      <div class="w-full flex-shrink-0 relative" style="width: 25%;">  
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" aria-label={`Read story: ${slide.title}`}>  
          
          {/* ✅ 2026 SEO MAXIMUM OPTIMIZATION: */}
          {/* මිනිස් ඇසට නොපෙනී Google Bot එකට පමණක් 100% ක්ම කියවිය හැකි පරිදි සකසන ලද ශීර්ෂ ටැගය (h3) */}
          <h3 class="sr-only opacity-0 absolute pointer-events-none">{slide.title}</h3>

          {/* ✅ IMAGE RATIO FIXED: පෙර workflow එකට ගැලපෙන පරිදි width/height 1200x450 ලෙස සුළු වශයෙන් නිවැරදි කළා CLS වැළැක්වීමට */}
          <div class="relative w-full aspect-[16/8] sm:aspect-[21/8] md:aspect-[24/8] bg-[#010203] overflow-hidden">  
            <img  
              src={slide.image}  
              alt={slide.title}  
              width={1200}  
              height={450}  
              loading={index === 0 ? "eager" : "lazy"}  
              decoding={index === 0 ? "sync" : "async"}  
              fetchpriority={index === 0 ? "high" : "low"}  
              class="w-full h-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"  
            />  
          </div>  
  
          <div class="absolute bottom-3 left-4 z-10">  
            <span class="bg-[#FFCC00] text-[#010203] px-2.5 py-1 text-[11px] sm:text-xs font-black rounded uppercase tracking-wider shadow-md">  
              {humanize(slide.category)}  
            </span>  
          </div>  
        </a>  
      </div>  
    ))}  
  </div>  
  
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-20">  
    {demoSlides.map((_, index) => (  
      <button  
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-[#01AD9F] scale-125' : 'bg-white/40'}`}  
        data-index={index}  
        aria-label={`Go to slide ${index + 1}`}  
      ></button>  
    ))}  
  </div>  
</div>  
  
<script>  
  // 글로벌 변수로 인터벌 저장 (Astro View Transitions ලික් වීම් වැළැක්වීමට)
  let slideInterval: any = null;

  function initSlider() {  
    const slider = document.getElementById('astro-featured-slider');  
    const wrapper = document.getElementById('slider-wrapper');  
    const dots = document.querySelectorAll('.slider-dot');  
  
    if (!slider || !wrapper || dots.length === 0) return;  
  
    // ✅ 2026 MEMORY FIX: දැනට ධාවනය වන පැරණි සිදුවීම්/Intervals තිබේ නම් ඒවා සම්පූර්ණයෙන්ම ඉවත් කරයි
    if (slideInterval) {
      clearInterval(slideInterval);
    }

    let currentIndex = 0;  
    const totalSlides = dots.length;  
    const intervalTime = 4000;  
  
    function updateSlider(index: number) {  
      currentIndex = index;  
      wrapper.style.transform = `translateX(-${index * 25}%)`;  
  
      dots.forEach((dot, i) => {  
        if (i === index) {  
          dot.classList.add('bg-[#01AD9F]', 'scale-125');  
          dot.classList.remove('bg-white/40');  
        } else {  
          dot.classList.remove('bg-[#01AD9F]', 'scale-125');  
          dot.classList.add('bg-white/40');  
        }  
      });  
    }  
  
    function startInterval() {  
      // මීට පෙර සාදන ලද interval එකක් තිබේ නම් නැවත clear කරයි
      if (slideInterval) clearInterval(slideInterval);
      slideInterval = setInterval(() => {  
        const nextIndex = (currentIndex + 1) % totalSlides;  
        updateSlider(nextIndex);  
      }, intervalTime);  
    }  
  
    function stopInterval() {  
      clearInterval(slideInterval);  
    }  
  
    dots.forEach((dot) => {  
      dot.addEventListener('click', (e) => {  
        stopInterval();  
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');  
        updateSlider(index);  
        startInterval();  
      });  
    });  
  
    let touchStartX = 0;  
    let touchEndX = 0;  
  
    slider.addEventListener('touchstart', (e) => {  
      touchStartX = (e as TouchEvent).changedTouches[0].screenX;  
      stopInterval();  
    }, { passive: true });  
  
    slider.addEventListener('touchend', (e) => {  
      touchEndX = (e as TouchEvent).changedTouches[0].screenX;  
      const diff = touchStartX - touchEndX;  
      if (Math.abs(diff) > 50) {  
        const nextIndex = diff > 0  
          ? (currentIndex + 1) % totalSlides  
          : (currentIndex - 1 + totalSlides) % totalSlides;  
        updateSlider(nextIndex);  
      }  
      startInterval();  
    }, { passive: true });  
  
    slider.addEventListener('mouseenter', stopInterval);  
    slider.addEventListener('mouseleave', startInterval);  
  
    startInterval();  
  }  
  
  // Astro View Transitions සහ Normal Loading ක්‍රම දෙකටම ගැලපෙන සේ ක්‍රියාත්මක කිරීම
  document.addEventListener('astro:page-load', initSlider);  
  
  // පිටුවෙන් පිටුවට යන විට පැරණි Interval එක මුළුමනින්ම නවත්වයි
  document.addEventListener('astro:before-preparation', () => {
    if (slideInterval) clearInterval(slideInterval);
  });
</script>
