---
import { Image } from "astro:assets";
import { humanize } from "@/lib/utils/textConverter";

// ✅ FIX: actual uploaded files .jpg format (src/assets/images/slider/) —
// format="webp" prop එක Image component එකේ දාලා තියෙන නිසා,
// Sharp විසින් build time එකේදී .jpg → .webp automatically convert කරයි.
// Output එක browser එකට යන්නේ optimized webp විදිහටම.
import slide1 from "@/assets/images/slider/slide-1.jpg";
import slide2 from "@/assets/images/slider/slide-2.jpg";
import slide3 from "@/assets/images/slider/slide-3.jpg";
import slide4 from "@/assets/images/slider/slide-4.jpg";

const demoSlides = [
  {
    id: "thaththa-duwa-wal-katha/",
    title: "thaththa duwa wal katha - තාත්තයි දුවයි වල් කතා",
    image: slide1,
    category: "Wal Katha"
  },
  {
    id: "methsala-akka-wal-katha/",
    title: "methsala akka wal katha - මෙත්සලා අක්කා වල් කතා",
    image: slide2,
    category: "Wela Katha"
  },
  {
    id: "nandage-duwa-wal-katha/",
    title: "Nandage duwa wal katha - නැන්දගේ දුව වල් කතා",
    image: slide3,
    category: "wala katha"
  },
  {
    id: "gedara-driver-wal-katha/",
    title: "Gedara driver wal katha - ගෙදර ඩ්‍රයිවර් වල් කතා",
    image: slide4,
    category: "True Story"
  }
];
---

<div 
  class="relative w-full overflow-hidden rounded-xl bg-[#010203] mb-8 border border-white/10" 
  id="astro-featured-slider"
  aria-label="Featured Stories Slider"
  aria-roledescription="carousel"
>
  <!-- ✅ WCAG: Live region — screen readers slide changes announce කරයි -->
  <div aria-live="polite" aria-atomic="true" class="sr-only" id="slider-live-region"></div>

  <div 
    class="flex will-change-transform" 
    id="slider-wrapper" 
    style="width: 400%; transform: translateX(0%); transition: transform 0.5s ease-in-out;"
    aria-label="Slides"
  >
    {demoSlides.map((slide, index) => (
      <div 
        class="w-full flex-shrink-0 relative" 
        style="width: 25%;"
        role="group"
        aria-roledescription="slide"
        aria-label={`Slide ${index + 1} of ${demoSlides.length}: ${slide.title}`}
        aria-hidden={index !== 0 ? "true" : "false"}
        id={`slide-${index}`}
      >
        <a 
          href={`/blog/${slide.id}`} 
          class="block w-full h-full group" 
          aria-label={`Read story: ${slide.title}`}
          tabindex={index !== 0 ? -1 : 0}
        >
          <!-- Heading hierarchy: index.astro h1 → Posts h2 → slider h2 (sr-only) -->
          <h2 class="sr-only">{slide.title}</h2>

          {/* ✅ IMAGE FIX: Astro <Image> component + layout="constrained"
              - layout="constrained" — site .container max-width:1000px එකට ගැලපෙන 
                responsive srcset/sizes auto-generate කරයි (100vw නෙවෙයි, 1000px max)
              - width/height — 8:3 aspect ratio (1000x375), parent CSS aspect-ratio:8/3 සමග match
              - quality={75} — visual quality maintain කරමින් file size අඩු කරයි
              - format="webp" — input .jpg වුණත් output එක webp බවට convert කරයි
              - Build time එකේදී Sharp විසින් breakpoints කිහිපයකට (mobile/tablet/desktop)
                resize + compress කරයි — දැන් display size එකට ගැලපෙන file එක විතරයි browser එකට යන්නේ */}
          <div 
            class="relative w-full bg-[#010203] overflow-hidden"
            style="aspect-ratio: 8/3;"
          >
            <Image
              src={slide.image}
              alt={slide.title}
              layout="constrained"
              width={1000}
              height={375}
              quality={75}
              format="webp"
              loading={index === 0 ? "eager" : "lazy"}
              decoding={index === 0 ? "sync" : "async"}
              fetchpriority={index === 0 ? "high" : "auto"}
              class="w-full h-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"
              aria-hidden="true"
            />
          </div>

          {/* Category badge — dark backdrop, WCAG contrast ≥ 4.5:1 */}
          <div class="absolute bottom-3 left-4 z-10">
            <span class="bg-[#FFCC00] text-[#010203] px-2.5 py-1 text-[11px] sm:text-xs font-black rounded uppercase tracking-wider shadow-md ring-1 ring-black/20">
              {humanize(slide.category)}
            </span>
          </div>

          {/* Story title overlay — visible on hover */}
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
            <div class="absolute bottom-10 left-4 right-4">
              <p class="text-white text-xs sm:text-sm font-semibold line-clamp-1 drop-shadow-md">
                {slide.title}
              </p>
            </div>
          </div>
        </a>
      </div>
    ))}
  </div>

  <!-- Slider dots — 44×44px touch target (WCAG 2.5.5) -->
  <div class="absolute bottom-1 right-2 flex gap-0 z-20" role="tablist" aria-label="Slide navigation">
    {demoSlides.map((slide, index) => (
      <button
        class={`slider-dot min-w-[44px] min-h-[44px] flex items-center justify-center focus:outline-none focus-visible:ring-2 focus-visible:ring-[#01AD9F] focus-visible:ring-offset-1 focus-visible:ring-offset-black rounded-lg`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}: ${slide.title}`}
        aria-selected={index === 0 ? "true" : "false"}
        role="tab"
        aria-controls={`slide-${index}`}
        type="button"
      >
        <span class={`block w-2.5 h-2.5 rounded-full transition-all duration-300 slider-dot-visual ${index === 0 ? 'bg-[#01AD9F] scale-125' : 'bg-white/40'}`}></span>
      </button>
    ))}
  </div>
</div>

<script>
  // ✅ Global interval variable — Astro View Transitions leak prevention
  let slideInterval: ReturnType<typeof setInterval> | null = null;

  function initSlider() {
    const slider = document.getElementById('astro-featured-slider');
    const wrapper = document.getElementById('slider-wrapper') as HTMLElement | null;
    const dots = document.querySelectorAll<HTMLButtonElement>('.slider-dot');
    const visualDots = document.querySelectorAll<HTMLElement>('.slider-dot-visual');
    const liveRegion = document.getElementById('slider-live-region');
    const slides = document.querySelectorAll<HTMLElement>('[role="group"][aria-roledescription="slide"]');

    if (!slider || !wrapper || dots.length === 0) return;

    if (slideInterval) {
      clearInterval(slideInterval);
      slideInterval = null;
    }

    let currentIndex = 0;
    const totalSlides = dots.length;
    const intervalTime = 4000;

    function updateSlider(index: number) {
      currentIndex = index;
      wrapper!.style.transform = `translateX(-${index * 25}%)`;

      visualDots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.add('bg-[#01AD9F]', 'scale-125');
          dot.classList.remove('bg-white/40');
        } else {
          dot.classList.remove('bg-[#01AD9F]', 'scale-125');
          dot.classList.add('bg-white/40');
        }
      });

      dots.forEach((dot, i) => {
        dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });

      slides.forEach((slide, i) => {
        slide.setAttribute('aria-hidden', i !== index ? 'true' : 'false');
        const link = slide.querySelector('a');
        if (link) link.setAttribute('tabindex', i !== index ? '-1' : '0');
      });

      if (liveRegion) {
        const slideData = [
          { title: "thaththa duwa wal katha" },
          { title: "methsala akka wal katha" },
          { title: "Nandage duwa wal katha" },
          { title: "Gedara driver wal katha" }
        ];
        liveRegion.textContent = `Slide ${index + 1} of ${totalSlides}: ${slideData[index]?.title ?? ''}`;
      }
    }

    function startInterval() {
      if (slideInterval) clearInterval(slideInterval);
      slideInterval = setInterval(() => {
        const nextIndex = (currentIndex + 1) % totalSlides;
        updateSlider(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      if (slideInterval) {
        clearInterval(slideInterval);
        slideInterval = null;
      }
    }

    slider.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') {
        stopInterval();
        updateSlider((currentIndex + 1) % totalSlides);
        startInterval();
      } else if (e.key === 'ArrowLeft') {
        stopInterval();
        updateSlider((currentIndex - 1 + totalSlides) % totalSlides);
        startInterval();
      }
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        stopInterval();
        const index = parseInt((e.currentTarget as HTMLElement).getAttribute('data-index') || '0');
        updateSlider(index);
        startInterval();
      });
    });

    let touchStartX = 0;
    let touchEndX = 0;

    slider.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      stopInterval();
    }, { passive: true });

    slider.addEventListener('touchend', (e) => {
      touchEndX = (e as TouchEvent).changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        const nextIndex = diff > 0
          ? (currentIndex + 1) % totalSlides
          : (currentIndex - 1 + totalSlides) % totalSlides;
        updateSlider(nextIndex);
      }
      startInterval();
    }, { passive: true });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);
    slider.addEventListener('focusin', stopInterval);
    slider.addEventListener('focusout', startInterval);

    startInterval();
  }

  document.addEventListener('astro:page-load', initSlider);

  document.addEventListener('astro:before-preparation', () => {
    if (slideInterval) {
      clearInterval(slideInterval);
      slideInterval = null;
    }
  });
</script>
