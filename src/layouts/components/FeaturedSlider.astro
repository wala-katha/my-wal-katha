---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7.5] sm:aspect-[21/7.5] md:aspect-[24/7.5] bg-gray-900 overflow-hidden">
    {demoSlides.map((slide, index) => (
      <div 
        class={`absolute inset-0 w-full h-full transition-opacity duration-300 slide-item ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" title={slide.title}>
          <Image
            src={slide.image}
            alt={slide.title}
            width={1200}
            height={400}
            quality="max"
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            /* MAXIMUM CLARITY: කිසිදු ශේඩින් එකක් නැත, පින්තූරය උපරිම පැහැදිලිව පෙනේ */
            class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.02]"
          />
          
          {/* ONLY CATEGORY TAG OVERLAY */}
          <div class="absolute bottom-3 left-4 z-20">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md pointer-events-none">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🧩 DYNAMIC KETU KETA (GRID BLOCKS) OVERLAY FOR ANIMATION */}
    <div id="grid-transition-overlay" class="absolute inset-0 pointer-events-none hidden grid-cols-5 grid-rows-4 z-30">
      {Array.from({ length: 20 }).map(() => (
        <div class="bg-gray-950 opacity-0 transition-opacity duration-200 ease-out transition-block"></div>
      ))}
    </div>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-20">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* SMOOTH BLOCK PIXELATION TRANSITION SCRIPT */}
<script>
  function initPixelatedSlider() {
    const slider = document.getElementById('astro-featured-slider');
    const slides = document.querySelectorAll('.slide-item');
    const dots = document.querySelectorAll('.slider-dot');
    const gridOverlay = document.getElementById('grid-transition-overlay');
    const blocks = document.querySelectorAll('.transition-block');
    
    if (!slider || slides.length === 0 || dots.length === 0 || !gridOverlay || blocks.length === 0) return;
    
    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000; // කොටු කැට මාරු වීමට කාලය තත්පර 5ක් දුන්නා
    let slideInterval: any;
    let isAnimating = false;

    function transitionToSlide(nextIndex: number) {
      if (isAnimating || nextIndex === currentIndex) return;
      isAnimating = true;

      // 1. කොටු ජාලය සක්‍රීය කර මතු කිරීම
      gridOverlay.classList.remove('hidden');
      gridOverlay.classList.add('grid');

      // 2. කොටු කැට එකින් එක සසම්බාවිතව (Randomly) තද කළු පැහැ ගැන්වීම
      const blockArray = Array.from(blocks);
      const shuffledBlocks = blockArray.sort(() => Math.random() - 0.5);
      
      shuffledBlocks.forEach((block, i) => {
        setTimeout(() => {
          block.classList.remove('opacity-0');
          block.classList.add('opacity-100');
        }, i * 15); // කොටු එකතු වන වේගය
      });

      // 3. කොටු සම්පූර්ණයෙන්ම වැසුණු පසු පින්තූරය පසුබිමෙන් මාරු කිරීම
      setTimeout(() => {
        // පරණ පෝස්ට් එක හංගලා අලුත් එක පෙන්වීම
        slides[currentIndex].classList.remove('opacity-100', 'z-10');
        slides[currentIndex].classList.add('opacity-0', 'z-0');
        
        slides[nextIndex].classList.remove('opacity-0', 'z-0');
        slides[nextIndex].classList.add('opacity-100', 'z-10');

        // ඩොට්ස් අප්ඩේට් කිරීම
        dots.forEach((dot, i) => {
          if (i === nextIndex) {
            dot.classList.add('bg-primary', 'scale-125');
            dot.classList.remove('bg-white/50');
          } else {
            dot.classList.remove('bg-primary', 'scale-125');
            dot.classList.add('bg-white/50');
          }
        });

        currentIndex = nextIndex;

        // 4. කොටු කැට නැවත එකින් එක නොපෙනී යාමට සැලැස්වීම (Reveal New Slide)
        shuffledBlocks.forEach((block, i) => {
          setTimeout(() => {
            block.classList.remove('opacity-100');
            block.classList.add('opacity-0');
          }, i * 15);
        });

        // 5. ඇනිමේෂන් එක සම්පූර්ණයෙන්ම අවසන් වූ පසු ඕවර්ලේ එක ක්ලීන් කිරීම
        setTimeout(() => {
          gridOverlay.classList.add('hidden');
          gridOverlay.classList.remove('grid');
          isAnimating = false;
        }, (shuffledBlocks.length * 15) + 200);

      }, (shuffledBlocks.length * 15) + 150);
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        transitionToSlide(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    // ඩොට්ස් ක්ලික් කිරීම්
    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        transitionToSlide(index);
        startInterval();
      });
    });

    // මවුස් එක උඩට ගිය විට ඔටෝ මාරු වීම නැවතීම
    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  // Astro පිටු මාරුවීම් වලදී නිවැරදිව ක්‍රියාත්මක වීම
  document.addEventListener('astro:page-load', initPixelatedSlider);
  initPixelatedSlider();
</script>
