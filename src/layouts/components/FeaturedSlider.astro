---
import { humanize } from "@/lib/utils/textConverter";  
  
const demoSlides = [  
  {  
    id: "thaththa-duwa-wal-katha/",  
    title: "තාත්තයි දුවයි වල් කතා",  
    enTitle: "thaththa duwa wal katha",
    image: "/images/slider/slide-1.webp",  
    category: "Wal Katha"  
  },  
  {  
    id: "methsala-akka-wal-katha/",  
    title: "මෙත්සලා අක්කා වල් කතා",  
    enTitle: "methsala akka wal katha",
    image: "/images/slider/slide-2.webp",  
    category: "Wela Katha"  
  },  
  {  
    id: "nandage-duwa-wal-katha/",  
    title: "නැන්දගේ දුව වල් කතා",  
    enTitle: "nandage duwa wal katha",
    image: "/images/slider/slide-3.webp",  
    category: "Wal Katha"  
  },  
  {  
    id: "gedara-driver-wal-katha/",  
    title: "ගෙදර ඩ්‍රයිවර් වල් කතා",  
    enTitle: "gedara driver wal katha",
    image: "/images/slider/slide-4.webp",  
    category: "True Story"  
  }  
];  
---  
  
<div class="relative w-full overflow-hidden rounded-xl bg-[#010203] mb-8 border border-white/10" id="astro-featured-slider" aria-roledescription="carousel" aria-label="Featured Stories">  
  <!-- CSS Scroll Snap භාවිතා කර Slider Wrapper එක සකසා ඇත (Better Performance) -->
  <div class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar" id="slider-wrapper">  
    {demoSlides.map((slide, index) => (  
      <div class="w-full flex-shrink-0 relative snap-start">  
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" aria-label={`කියවන්න: ${slide.title}`}>  
          <div class="relative w-full aspect-[16/8] sm:aspect-[21/8] md:aspect-[24/8] bg-[#010203] overflow-hidden">  
            <img  
              src={slide.image}  
              alt={`${slide.title} - ${slide.enTitle}`} <!-- SEO Friendly Alt Tag -->
              width={900}  
              height={338}  
              loading={index === 0 ? "eager" : "lazy"}  
              decoding={index === 0 ? "sync" : "async"}  
              fetchpriority={index === 0 ? "high" : "low"}  
              class="w-full h-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"  
            />
            <!-- Text එක කැපී පෙනීමට Gradient Overlay එකක් එක් කර ඇත -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          </div>  
  
          <!-- SEO සහ Content Hierarchy සකසා ඇත -->
          <div class="absolute bottom-4 left-4 z-10 flex flex-col gap-2 max-w-[85%]">
            <span class="w-max bg-[#FFCC00] text-[#010203] px-2.5 py-1 text-[11px] sm:text-xs font-black rounded uppercase tracking-wider shadow-md">  
              {humanize(slide.category)}  
            </span>  
            <h3 class="text-white text-base sm:text-lg md:text-xl font-bold line-clamp-1 drop-shadow-md">
              {slide.title} <span class="text-xs sm:text-sm font-normal text-gray-300 block sm:inline sm:ml-2">({slide.enTitle})</span>
            </h3>
          </div>  
        </a>  
      </div>  
    ))}  
  </div>  
  
  <div class="absolute bottom-4 right-4 flex gap-1.5 z-20">  
    {demoSlides.map((_, index) => (  
      <button  
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-[#01AD9F] scale-125' : 'bg-white/40'}`}  
        data-index={index}  
        aria-label={`Go to slide ${index + 1}`}  
      ></button>  
    ))}  
  </div>  
</div>  

<style>
  /* Scrollbar එක සඟවන්න */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
  
<script>  
  function initSlider() {  
    const slider = document.getElementById('astro-featured-slider');  
    const wrapper = document.getElementById('slider-wrapper');  
    const dots = document.querySelectorAll('.slider-dot');  
  
    if (!slider || !wrapper || dots.length === 0) return;  
  
    let currentIndex = 0;  
    const totalSlides = dots.length;  
    const intervalTime = 5000; // 2026 දී කියවීමේ පහසුවට තත්පර 5ක් දීම වඩා සුදුසුයි
    let slideInterval: ReturnType<typeof setInterval>;  
  
    function updateSlider(index: number) {  
      currentIndex = index;
      const slideWidth = wrapper.clientWidth;
      wrapper.scrollTo({ left: slideWidth * index, behavior: 'smooth' });  
  
      dots.forEach((dot, i) => {  
        if (i === index) {  
          dot.classList.add('bg-[#01AD9F]', 'scale-125');  
          dot.classList.remove('bg-white/40');  
        } else {  
          dot.classList.remove('bg-[#01AD9F]', 'scale-125');  
          dot.classList.add('bg-white/40');  
        }  
      });  
    }  
  
    function startInterval() {  
      slideInterval = setInterval(() => {  
        const nextIndex = (currentIndex + 1) % totalSlides;  
        updateSlider(nextIndex);  
      }, intervalTime);  
    }  
  
    function stopInterval() {  
      clearInterval(slideInterval);  
    }  
  
    dots.forEach((dot) => {  
      dot.addEventListener('click', (e) => {  
        stopInterval();  
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');  
        updateSlider(index);  
        startInterval();  
      });  
    });  
  
    // Scroll එක නිරීක්ෂණය කර Dot එක අප්ඩේට් කිරීම (User manual swipe කළහොත්)
    let isScrolling: ReturnType<typeof setTimeout>;
    wrapper.addEventListener('scroll', () => {
      clearTimeout(isScrolling);
      isScrolling = setTimeout(() => {
        const index = Math.round(wrapper.scrollLeft / wrapper.clientWidth);
        if(index !== currentIndex) {
          currentIndex = index;
          dots.forEach((dot, i) => {  
            if (i === index) {  
              dot.classList.add('bg-[#01AD9F]', 'scale-125');  
              dot.classList.remove('bg-white/40');  
            } else {  
              dot.classList.remove('bg-[#01AD9F]', 'scale-125');  
              dot.classList.add('bg-white/40');  
            }  
          });
        }
      }, 100);
    }, { passive: true });
  
    slider.addEventListener('mouseenter', stopInterval);  
    slider.addEventListener('mouseleave', startInterval);  
    slider.addEventListener('touchstart', stopInterval, { passive: true });
    slider.addEventListener('touchend', startInterval, { passive: true });
  
    startInterval();  
  }  
  
  document.addEventListener('astro:page-load', initSlider);  
  initSlider();  
</script>
