---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7] sm:aspect-[21/7] md:aspect-[24/7] bg-gray-900 overflow-hidden" id="slider-view-box">
    {demoSlides.map((slide, index) => (
      <div 
        class="absolute inset-0 w-full h-full slide-item"
        style={`opacity: ${index === 0 ? '1' : '0'}; z-index: ${index === 0 ? '20' : '10'}; transition: opacity 1000ms ease-in-out, filter 1000ms ease-in-out;`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" title={slide.title}>
          <Image
            src={slide.image}
            alt={slide.title}
            width={1200}
            height={525}
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            /* MAXIMUM CLARITY: කිසිදු අඳුරු ෆිල්ටරයක් නොමැත, පින්තූරය උපරිම පැහැදිලිව පෙනේ */
            class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.01]"
          />
          
          {/* ONLY CATEGORY TAG OVERLAY */}
          <div class="absolute bottom-3 left-4 z-30">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md pointer-events-none">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🧩 FINE PARTICLES CANVAS LAYER (පින්තූරය වැසී යන සේ ඉහළට යන කැට සඳහා) */}
    <canvas id="particle-transition-canvas" class="absolute inset-0 pointer-events-none z-25 hidden w-full h-full"></canvas>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-40">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* SMOOTH UPWARD PARTICLES & BLUR TRANSITION SCRIPT */}
<script>
  let slideInterval: any;
  let animationFrameId: any;

  function initFineParticleSlider() {
    // Astro View Transitions වලදී පරණ ලූප් සහ ඉන්ටර්වල්ස් පිරිසිදු කිරීම (Anti-crash / Strict SEO)
    if (slideInterval) clearInterval(slideInterval);
    if (animationFrameId) cancelAnimationFrame(animationFrameId);

    const slider = document.getElementById('astro-featured-slider');
    const slides = document.querySelectorAll('.slide-item') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('.slider-dot');
    const canvas = document.getElementById('particle-transition-canvas') as HTMLCanvasElement;
    
    if (!slider || slides.length === 0 || dots.length === 0 || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000; // තත්පර 5න් 5ට මාරු වීම
    let isAnimating = false;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // 🧩 උඩට යන කුඩා කැට ව්‍යුහය (Upward Fine Particle Class)
    class FineParticle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      speedX: number;
      alpha: number;
      fadeSpeed: number;

      constructor(canvasWidth: number, canvasHeight: number) {
        // පින්තූරයේ යට ඉඳන් උඩටම මතු විය යුතු නිසා ආරම්භය පහළින් ලබා දේ
        this.x = Math.random() * canvasWidth;
        this.y = canvasHeight + (Math.random() * 20);
        // උපරිම පොඩි සියුම් කැට (Fine Pixels) 1.2px සිට 3.5px දක්වා
        this.size = Math.random() * 2.3 + 1.2;
        // ඉහළට විසිවන වේගය (Upward motion)
        this.speedY = -(Math.random() * 3 + 2.5);
        // දෙපැත්තට පොඩ්ඩක් සෙලවීම සඳහා
        this.speedX = (Math.random() - 0.5) * 1;
        this.alpha = 1;
        this.fadeSpeed = Math.random() * 0.012 + 0.008;
      }

      update() {
        this.y += this.speedY;
        this.x += this.speedX;
        this.alpha -= this.fadeSpeed;
      }

      draw(context: CanvasRenderingContext2D) {
        context.save();
        context.globalAlpha = Math.max(0, this.alpha);
        context.fillStyle = '#111827'; // සයිට් එකේ ඩාර්ක් පසුබිමට ගැළපෙන කැට වර්ණය
        context.beginPath();
        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        context.fill();
        context.restore();
      }
    }

    let particles: FineParticle[] = [];

    function runTransition(nextIndex: number) {
      if (isAnimating) return;
      isAnimating = true;

      const currentSlide = slides[currentIndex];
      const nextSlide = slides[nextIndex];

      // [CRITICAL FIX]: කළු තිරය නොපෙනී සිටීමට, ඊළඟ පින්තූරය දැනටමත් යටින් සූදානම් කර z-index එක සකසයි
      nextSlide.style.zIndex = '15';
      nextSlide.style.opacity = '1';
      nextSlide.style.filter = 'blur(0px)';

      currentSlide.style.zIndex = '20';

      // කැට මතුවීම ආරම්භය
      canvas.classList.remove('hidden');
      particles = [];
      let startTime = Date.now();
      const duration = 1200; // ඇනිමේෂන් කාලය මිලි තත්පර 1200
      let imageSwapped = false;

      function animationLoop() {
        const elapsed = Date.now() - startTime;
        ctx!.clearRect(0, 0, canvas.width, canvas.height);

        // යට සිට උඩට කැට එක දිගට ජනනය කිරීම
        if (elapsed < duration * 0.7) {
          for (let i = 0; i < 25; i++) {
            particles.push(new FineParticle(canvas.width, canvas.height));
          }
        }

        // කැට අප්ඩේට් කර ඇඳීම
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.update();
          p.draw(ctx!);
          if (p.alpha <= 0 || p.y < 0) {
            particles.splice(i, 1);
          }
        }

        // ⚡ [SMART CROSSWARD SWAP]: මැද හරියේදී පරණ පින්තූරය වේගයෙන් බොඳ කර මකා දමා අලුත් එක මතු කිරීම
        if (elapsed >= duration * 0.35) {
          const progress = (elapsed - duration * 0.35) / (duration * 0.65);
          const blurValue = Math.min(15, (elapsed / (duration * 0.35)) * 8);
          
          currentSlide.style.filter = `blur(${blurValue}px)`;
          currentSlide.style.opacity = Math.max(0, 1 - progress).toString();

          if (!imageSwapped) {
            imageSwapped = true;
            // ඩොට්ස් අප්ඩේට් කිරීම
            dots.forEach((dot, i) => {
              if (i === nextIndex) {
                dot.classList.add('bg-primary', 'scale-125');
                dot.classList.remove('bg-white/50');
              } else {
                dot.classList.remove('bg-primary', 'scale-125');
                dot.classList.add('bg-white/50');
              }
            });
          }
        }

        if (elapsed < duration || particles.length > 0) {
          animationFrameId = requestAnimationFrame(animationLoop);
        } else {
          // ඇනිමේෂන් එක ඉවර වූ පසු ස්ටයිල්ස් පිළිවෙලකට සකස් කිරීම
          canvas.classList.add('hidden');
          currentSlide.style.zIndex = '10';
          currentSlide.style.opacity = '0';
          currentSlide.style.filter = 'blur(0px)';
          
          nextSlide.style.zIndex = '20';
          currentIndex = nextIndex;
          isAnimating = false;
        }
      }

      animationFrameId = requestAnimationFrame(animationLoop);
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        runTransition(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    // Dots ක්ලික් කිරීම් පාලනය
    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        runTransition(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  // Astro Lifecycle එකට 100%ක් ගැලපීම
  document.addEventListener('astro:page-load', initFineParticleSlider);
  initFineParticleSlider();
</script>
