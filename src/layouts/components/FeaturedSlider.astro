---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7] sm:aspect-[21/7] md:aspect-[24/7] bg-gray-950 overflow-hidden" id="slider-view-box">
    {demoSlides.map((slide, index) => (
      <div 
        class="absolute inset-0 w-full h-full slide-item"
        style={`opacity: ${index === 0 ? '1' : '0'}; z-index: ${index === 0 ? '20' : '10'}; filter: blur(0px); transition: opacity 1200ms ease-in-out, filter 1200ms ease-in-out;`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" title={slide.title}>
          <Image
            src={slide.image}
            alt={slide.title}
            width={1200}
            height={525}
            quality="max"
            loading={index === 0 ? "eager" : "lazy"}
            decoding="async"
            /* MAXIMUM CLARITY FIX: කිසිදු අඳුරු Overlay එකක් නොමැත, පින්තූරය උපරිම පිරිසිදුවට පෙනේ */
            class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.01]"
          />
          
          {/* ONLY CATEGORY TAG OVERLAY */}
          <div class="absolute bottom-3 left-4 z-30">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md pointer-events-none">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🧩 FINE PARTICLES CANVAS LAYER (Z-Index එක 25 කර පින්තූර අතර මැදින් කැට මතුවීමට සැලැස්වීම) */}
    <canvas id="particle-transition-canvas" class="absolute inset-0 pointer-events-none z-25 hidden w-full h-full"></canvas>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-40">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* SMOOTH PARTICLES & BLUR TRANSITION SCRIPT */}
<script>
  function initFineParticleSlider() {
    const slider = document.getElementById('astro-featured-slider');
    const slides = document.querySelectorAll('.slide-item') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('.slider-dot');
    const canvas = document.getElementById('particle-transition-canvas') as HTMLCanvasElement;
    
    if (!slider || slides.length === 0 || dots.length === 0 || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000; // තත්පර 5න් 5ට මාරු වීම
    let slideInterval: any;
    let isAnimating = false;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // 🌟 GLOWING WHITE PARTICLES LOGIC: යට සිට උඩට යන ලස්සන අර්ධ-පාරදෘශ්‍ය කැට
    class Particle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      alpha: number;
      fadeSpeed: number;

      constructor(startX: number, startY: number) {
        this.x = startX;
        this.y = startY;
        this.size = Math.random() * 2 + 1; // පොඩි සියුම් කැට (1px - 3px)
        this.speedY = -(Math.random() * 2.5 + 1.5); // ඉහළට යන වේගය
        this.alpha = Math.random() * 0.5 + 0.5;
        this.fadeSpeed = Math.random() * 0.01 + 0.005;
      }

      update() {
        this.y += this.speedY;
        this.alpha -= this.fadeSpeed;
      }

      draw(context: CanvasRenderingContext2D) {
        context.save();
        context.globalAlpha = Math.max(0, this.alpha);
        // පින්තූර උපරිම පැහැදිලි නිසා කැට ලස්සනට කැපී පෙනෙන්න සුදු/රන්වන් මිශ්‍ර ග්ලෝ එකක් දුන්නා
        context.fillStyle = 'rgba(255, 255, 255, 0.8)';
        context.shadowBlur = 4;
        context.shadowColor = '#fff';
        context.beginPath();
        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        context.fill();
        context.restore();
      }
    }

    let particles: Particle[] = [];

    function animateParticles(callback: () => void) {
      canvas.classList.remove('hidden');
      particles = [];
      let startTime = Date.now();
      const duration = 1200; // සම්පූර්ණ ට්‍රාන්සිෂන් කාලය මිලි තත්පර 1200
      let callbackTriggered = false;

      function loop() {
        const elapsed = Date.now() - startTime;
        ctx!.clearRect(0, 0, canvas.width, canvas.height);

        // මුළු ස්ලයිඩරයේම යට පැත්තෙන් කැට ක්‍රමයෙන් ඉහළට විසි වීම
        if (elapsed < duration * 0.7) {
          for (let i = 0; i < 8; i++) {
            const startX = Math.random() * canvas.width;
            particles.push(new Particle(startX, canvas.height + 5));
          }
        }

        particles.forEach((particle, index) => {
          particle.update();
          particle.draw(ctx!);
          if (particle.alpha <= 0 || particle.y < 0) {
            particles.splice(index, 1);
          }
        });

        // 🔄 NO BLACK SCREEN FIX: ඇනිමේෂන් එක මැදදී (මිලි තත්පර 500 දී) අලුත් පින්තූරය ස්මූත් ලෙස මාරු කිරීම
        if (elapsed >= 500 && !callbackTriggered) {
          callbackTriggered = true;
          callback();
        }

        if (elapsed < duration || particles.length > 0) {
          requestAnimationFrame(loop);
        } else {
          canvas.classList.add('hidden');
          isAnimating = false;
        }
      }

      loop();
    }

    function transitionToSlide(nextIndex: number) {
      if (isAnimating || nextIndex === currentIndex) return;
      isAnimating = true;

      const currentSlide = slides[currentIndex];
      const nextSlide = slides[nextIndex];

      // 1. ඊළඟ පින්තූරය පරණ එකට යටින් සූදානම් කර තැබීම (කළු පසුබිම පෙනීම වැළැක්වීමට)
      nextSlide.style.zIndex = '15';
      nextSlide.style.opacity = '1';
      nextSlide.style.filter = 'blur(0px)';

      // 2. කැට ඉහළට යන ගමන් පරණ පින්තූරය බ්ලර් වී මැකී යාම ආරම්භ කිරීම
      animateParticles(() => {
        currentSlide.style.filter = 'blur(15px)';
        currentSlide.style.opacity = '0';
        currentSlide.style.zIndex = '10';

        // 3. අලුත් පින්තූරය ප්‍රධාන ස්ථරය (Main Layer) බවට පත් කිරීම
        nextSlide.style.zIndex = '20';

        // ඩොට්ස් අප්ඩේට් කිරීම
        dots.forEach((dot, i) => {
          if (i === nextIndex) {
            dot.classList.add('bg-primary', 'scale-125');
            dot.classList.remove('bg-white/50');
          } else {
            dot.classList.remove('bg-primary', 'scale-125');
            dot.classList.add('bg-white/50');
          }
        });

        // ඊළඟ මාරුව සඳහා පරණ පින්තූරයේ ස්ටයිල්ස් නිවැරදිව රීසෙට් කිරීම
        setTimeout(() => {
          if (currentIndex !== nextIndex) {
            currentSlide.style.filter = 'blur(0px)';
          }
        }, 1200);

        currentIndex = nextIndex;
      });
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        transitionToSlide(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        transitionToSlide(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  document.addEventListener('astro:page-load', initFineParticleSlider);
  initFineParticleSlider();
</script>
