import { Image } from "astro:assets";

// ඩෙමෝ දත්ත: පසුව ඔයාට අවශ්‍ය පරිදි මේ ලින්ක්ස් වෙනස් කරගත හැක
const demoSlides = [
  {
    id: "mali-wal-katha",
    title: "මේල්ලිම් මෙම් - Mali Wal Katha",
