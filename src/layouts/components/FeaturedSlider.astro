---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg" id="astro-featured-slider">
  {/* SLIDER WRAPPER */}
  <div class="flex transition-transform duration-500 ease-in-out" id="slider-wrapper" style="width: 400%;">
    {demoSlides.map((slide, index) => (
      <div class="w-full flex-shrink-0 relative" style="width: 25%;">
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group">
          
          {/* SMART HEIGHT DECREASE: උස දශමයක් අඩු කිරීමට aspect ratios සකස් කරන ලදී */}
          <div class="relative w-full aspect-[16/8] sm:aspect-[21/8] md:aspect-[24/8] bg-gray-900">
            <Image
              src={slide.image}
              alt={slide.title}
              width={1200}
              height={450}
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
              /* object-cover මඟින් පින්තූරය බොක්ස් එක පුරාම පැහැදිලිව පෙන්වයි */
              class="w-full h-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"
            />
            {/* NO BLACK GRADIENT: කළු ශේඩින්ග් එක සම්පූර්ණයෙන්ම ඉවත් කර පින්තූරය 100% පැහැදිලිව පෙනෙන්නට සැලැස්වීම */}
            <div class="absolute inset-0 bg-transparent"></div>
          </div>
          
          {/* POST DETAILS OVERLAY */}
          <div class="absolute bottom-0 inset-x-0 p-4 sm:p-6 md:p-8 text-white z-10">
            {/* CATEGORY ONLY: දිනය සම්පූර්ණයෙන්ම ඉවත් කරන ලදී */}
            <div class="flex items-center mb-2">
              <span class="bg-primary text-white px-2 py-0.5 rounded text-[11px] sm:text-xs font-bold uppercase tracking-wider shadow-sm">
                {humanize(slide.category)}
              </span>
            </div>
            
            {/* TITLE WITH TEXT SHADOW FOR HIGH READABILITY */}
            <h2 class="text-sm sm:text-lg md:text-2xl font-bold line-clamp-2 leading-tight group-hover:text-primary transition duration-300 [text-shadow:_0_2px_4px_rgba(0,0,0,0.8)]">
              {slide.title}
            </h2>
          </div>
        </a>
      </div>
    ))}
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-20">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* LIGHTWEIGHT AUTOMATIC SLIDER SCRIPT */}
<script>
  function initSlider() {
    const slider = document.getElementById('astro-featured-slider');
    const wrapper = document.getElementById('slider-wrapper');
    const dots = document.querySelectorAll('.slider-dot');
    
    if (!slider || !wrapper || dots.length === 0) return;
    
    let currentIndex = 0;
    const totalSlides = dots.length;
    const intervalTime = 4000;
    let slideInterval: any;

    function updateSlider(index: number) {
      currentIndex = index;
      wrapper.style.transform = `translateX(-${index * 25}%)`;
      
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.add('bg-primary', 'scale-125');
          dot.classList.remove('bg-white/50');
        } else {
          dot.classList.remove('bg-primary', 'scale-125');
          dot.classList.add('bg-white/50');
        }
      });
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        updateSlider(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        updateSlider(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  document.addEventListener('astro:page-load', initSlider);
  initSlider();
</script>
