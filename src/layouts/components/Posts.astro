---
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt, BiPurchaseTagAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;

const allGlobalPosts = await getSinglePage("posts");
const allTags = allGlobalPosts.flatMap((post) => post.data.tags || []);
const uniqueTags = [...new Set(allTags)].filter(Boolean);
---

<div class={`w-full ${className} bg-[#010203]`}>
  {/* ✅ FIX: col-4 → col-6 — 3ක් වෙනුවට 2ක් per row, posts විශාල පෙනේ */}
  <div class={`row gy-5 gx-3 sm:gx-5 ${posts.length == 1 ? "justify-center" : ""} `}>
    {
      posts.map((post, i: number) => (
        <div class="col-6 flex flex-col justify-between">
          {post.data.image && (
            <a
              href={`/blog/${post.id}/`}
              class="rounded-lg block hover:text-primary overflow-hidden group relative border border-white/10"
              style="aspect-ratio: 2 / 3;"
            >
              <Image
                class="group-hover:scale-[1.04] transition duration-300 w-full h-full object-contain"
                src={post.data.image}
                alt={post.data.title}
                width={750}
                height={1125}
                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                loading={i < 2 ? "eager" : "lazy"}
                decoding="async"
              />
            </a>
          )}

          <ul class="mt-2 mb-1 flex flex-wrap items-center text-[#F8F8FF]/90 text-[11px] sm:text-sm justify-between">
            <li class="flex items-center flex-wrap">
              <BiCategoryAlt className="mr-0.5 h-3.5 w-3.5 sm:h-[16px] sm:w-[16px] text-[#01AD9F]" />
              <ul>
                {post.data.categories.slice(0, 1).map((category) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}/`}
                      class="hover:text-primary font-black text-[10px] sm:text-xs bg-white/10 px-1.5 sm:px-2 py-0.5 rounded text-[#F8F8FF]"
                    >
                      {humanize(category)}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
            <li class="hidden xs:flex items-center flex-wrap font-bold text-[10px] sm:text-xs text-[#F8F8FF]/80">
              <BiCalendarEdit className="mr-0.5 h-3.5 w-3.5 sm:h-4 sm:w-4 text-[#01AD9F]" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>

          <h3 class="mb-1 line-clamp-2 leading-tight">
            <a
              href={`/blog/${post.id}/`}
              class="block hover:text-primary transition duration-300 text-sm sm:text-base font-black text-[#F8F8FF]"
            >
              {post.data.title}
            </a>
          </h3>

          <p class="text-[#F8F8FF]/80 text-xs sm:text-sm line-clamp-2 mb-2 leading-snug">{plainify(post.body ?? "")}</p>

          <div class="flex items-center justify-between border-t border-white/10 pt-2 sm:pt-3 mt-auto gap-2">
            {authors
              .filter((author) =>
                post.data.authors
                  .map((author) => slugify(author))
                  .includes(slugify(author.data.title))
              )
              .slice(0, 1)
              .map((author) => (
                <a
                  href={`/authors/${slugify(author.data.title)}/`}
                  class="flex items-center hover:text-primary text-[11px] sm:text-xs font-bold text-[#F8F8FF] min-w-0 flex-shrink-1"
                >
                  {author.data.image && (
                    <img
                      src={author.data.image}
                      alt={author.data.title}
                      width={24}
                      height={24}
                      loading="lazy"
                      decoding="async"
                      class="mr-1 h-5 w-5 sm:h-5 sm:w-5 rounded-full object-cover flex-shrink-0 border border-white/20"
                    />
                  )}
                  <span class="truncate">{author.data.title}</span>
                </a>
              ))}

            <a
              href={`/blog/${post.id}/`}
              class="text-[10px] sm:text-xs bg-[#01AD9F] text-white px-3 sm:px-6 py-1.5 rounded-full hover:bg-opacity-90 transition-all font-black whitespace-nowrap flex-grow text-center max-w-[100px]"
            >
              Read
            </a>
          </div>
        </div>
      ))
    }
  </div>

  {uniqueTags.length > 0 && (
    <div class="mt-12 p-4 sm:p-6 bg-[#FFCC00] rounded-xl border border-[#E6B800]">
      <div class="flex items-center gap-2 mb-4 border-b border-[#010203]/10 pb-2">
        <BiPurchaseTagAlt className="text-[#010203] h-5 w-5" />
        <h4 class="text-sm sm:text-base font-black text-[#010203]">Labels (ටැග්ස්)</h4>
      </div>

      <div class="relative flex flex-col">
        <nav aria-label="Tags Cloud" class="transition-all duration-300 ease-in-out overflow-hidden max-h-[110px]" id="tags-toggle-container">
          <ul class="flex flex-wrap gap-2 m-0 p-0 list-none">
            {uniqueTags.map((tag, index) => (
              <li class={`tag-item-wrap ${index >= 12 ? 'hidden-tag hidden' : ''}`}>
                <a
                  href={`/tags/${slugify(tag)}/`}
                  rel="tag"
                  class="text-[11px] sm:text-xs bg-[#010203] text-white font-black tracking-wide px-2.5 py-1.5 rounded-md border border-black hover:bg-[#01AD9F] hover:text-white transition-all shadow-sm flex items-center gap-0.5"
                  title={`${tag} කතා සියල්ල මෙතනින් බලන්න`}
                  aria-label={`View posts tagged with ${tag}`}
                >
                  <span class="opacity-50 text-white font-normal">#</span>{humanize(tag)}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        {uniqueTags.length > 12 && (
          <div class="mt-5 flex justify-center w-full">
            <button
              id="btn-toggle-tags"
              type="button"
              class="text-[11px] sm:text-xs bg-[#010203] text-white font-black px-5 py-2 rounded-full shadow-md hover:bg-[#01AD9F] transition-all flex items-center gap-1 cursor-pointer z-10"
            >
              <span>Show All Tags</span>
            </button>
          </div>
        )}
      </div>
    </div>
  )}
</div>

<script>
  function initTagsToggler() {
    const btn = document.getElementById('btn-toggle-tags');
    const container = document.getElementById('tags-toggle-container');
    const hiddenTags = document.querySelectorAll('.hidden-tag');

    if (!btn || !container || hiddenTags.length === 0) return;

    let isOpen = false;

    btn.addEventListener('click', () => {
      isOpen = !isOpen;

      if (isOpen) {
        container.style.maxHeight = '2000px';
        hiddenTags.forEach(tag => tag.classList.remove('hidden'));
        btn.querySelector('span')!.textContent = 'Show Less';
      } else {
        container.style.maxHeight = '110px';
        btn.querySelector('span')!.textContent = 'Show All Tags';

        setTimeout(() => {
          if (!isOpen) {
            hiddenTags.forEach(tag => tag.classList.add('hidden'));
          }
        }, 300);
      }
    });
  }

  document.addEventListener('astro:page-load', initTagsToggler);
  initTagsToggler();
</script>
