---
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt, BiPurchaseTagAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;

// 🎯 HIGH-PERFORMANCE SEO: සයිට් එකේ තියෙන හැම පෝස්ට් එකකින්ම අද්විතීය (Unique) Tags ටික ඔටෝමැටිකවම එකතු කරගැනීම
const allTags = posts.flatMap((post) => post.data.tags || []);
const uniqueTags = [...new Set(allTags)].filter(Boolean);
---

<div class={`w-full ${className}`}>
  {/* ප්‍රධාන පෝස්ට් ග්‍රිඩ් එක */}
  <div class={`row gy-4 gx-2 sm:gx-4 ${posts.length == 1 ? "justify-center" : ""} `}>
    {
      posts.map((post, i: number) => (
        <div class="col-4 flex flex-col justify-between">
          {post.data.image && (
            <a
              href={`/blog/${post.id}/`}
              class="rounded-lg block hover:text-primary overflow-hidden group relative"
              style="aspect-ratio: 2 / 3;"
            >
              <Image
                class="group-hover:scale-[1.04] transition duration-300 w-full h-full object-contain"
                src={post.data.image}
                alt={post.data.title}
                width={500}
                height={750}
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
              />
            </a>
          )}
          
          <ul class="mt-2 mb-1 flex flex-wrap items-center text-text text-[10px] sm:text-sm justify-between">
            <li class="flex items-center flex-wrap">
              <BiCategoryAlt className="mr-0.5 h-3 w-3 sm:h-[16px] sm:w-[16px] text-gray-600" />
              <ul>
                {post.data.categories.slice(0, 1).map((category) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}/`}
                      class="hover:text-primary font-bold text-[9px] sm:text-xs bg-gray-100 dark:bg-darkmode-theme-light px-1 sm:px-2 py-0.5 rounded"
                    >
                      {humanize(category)}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
            <li class="hidden xs:flex items-center flex-wrap font-medium text-[9px] sm:text-xs text-gray-500">
              <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>

          <h3 class="mb-1 line-clamp-2 leading-tight">
            <a
              href={`/blog/${post.id}/`}
              class="block hover:text-primary transition duration-300 text-xs sm:text-base font-bold"
            >
              {post.data.title}
            </a>
          </h3>

          <p class="text-text text-[11px] sm:text-sm line-clamp-2 mb-2 leading-snug">{plainify(post.body ?? "")}</p>

          <div class="flex items-center justify-between border-t border-gray-100 pt-1.5 sm:pt-3 mt-auto gap-2">
            {authors
              .filter((author) =>
                post.data.authors
                  .map((author) => slugify(author))
                  .includes(slugify(author.data.title))
              )
              .slice(0, 1)
              .map((author) => (
                <a
                  href={`/authors/${slugify(author.data.title)}/`}
                  class="flex items-center hover:text-primary text-[10px] sm:text-xs font-medium min-w-0 flex-shrink-1"
                >
                  {author.data.image && (
                    <Image
                      src={author.data.image}
                      alt={author.data.title}
                      height={24}
                      width={24}
                      class="mr-1 h-4 w-4 sm:h-5 sm:w-5 rounded-full object-cover flex-shrink-0"
                    />
                  )}
                  <span class="truncate">{author.data.title}</span>
                </a>
              ))}
              
            <a 
              href={`/blog/${post.id}/`} 
              class="text-[9px] sm:text-xs bg-primary text-white px-3 sm:px-6 py-1 sm:py-1.5 rounded-full hover:bg-opacity-90 transition-all font-medium whitespace-nowrap flex-grow text-center max-w-[100px]"
            >
              Read
            </a>
          </div>
        </div>
      ))
    }
  </div>

  {/* 🏷️ Blogger Style Labels Section (SEO Optimized) */}
  {uniqueTags.length > 0 && (
    <div class="mt-12 p-4 sm:p-6 bg-gray-50 dark:bg-darkmode-theme-light rounded-xl border border-gray-100 dark:border-darkmode-border">
      <div class="flex items-center gap-2 mb-4 border-b border-gray-200 dark:border-darkmode-border pb-2">
        <BiPurchaseTagAlt className="text-primary h-5 w-5 animate-pulse" />
        <h4 class="text-sm sm:text-base font-bold text-dark dark:text-darkmode-text">Labels (ටැග්ස්)</h4>
      </div>
      
      {/* Tags Wrapper */}
      <div class="relative flex flex-col">
        {/* BUTTON එක හැංගීම වැළැක්වීමට max-h එක ඉවත් කර ලිස්ට් එක පාලනය ජාවාස්ක්‍රිප්ට් එකට පමණක් භාර දුන්නා */}
        <div class="flex flex-wrap gap-2 transition-all duration-500 ease-in-out" id="tags-toggle-container">
          {uniqueTags.map((tag, index) => (
            <a
              href={`/tags/${slugify(tag)}/`}
              rel="tag"
              class={`text-[11px] sm:text-xs bg-gray-950 dark:bg-black text-white px-2.5 py-1.5 rounded-md border border-gray-900 hover:bg-primary hover:text-white dark:hover:bg-primary transition-all font-medium shadow-sm flex items-center gap-1 tag-item ${index >= 12 ? 'hidden-tag hidden' : ''}`}
              title={`${tag} කතා බලන්න`}
            >
              <span class="opacity-70 text-white font-bold">#</span>{humanize(tag)}
            </a>
          ))}
        </div>

        {/* 🔘 SHOW ALL / SHOW LESS BUTTON (100% FIXED: කිසිවිටකත් නොසැඟවී පැහැදිලිව පෙනේ) */}
        {uniqueTags.length > 12 && (
          <div class="mt-5 flex justify-center w-full">
            <button
              id="btn-toggle-tags"
              type="button"
              class="text-[11px] sm:text-xs bg-primary text-white font-bold px-5 py-2 rounded-full shadow-md hover:bg-opacity-90 transition-all flex items-center gap-1 cursor-pointer z-10"
            >
              <span>Show All Tags</span>
            </button>
          </div>
        )}
      </div>
    </div>
  )}
</div>

{/* SMOOTH SHOW MORE / LESS SCRIPT (ASTRO COMPATIBLE) */}
<script>
  function initTagsToggler() {
    const btn = document.getElementById('btn-toggle-tags');
    const hiddenTags = document.querySelectorAll('.hidden-tag');
    
    if (!btn || hiddenTags.length === 0) return;
    
    let isOpen = false;
    
    btn.addEventListener('click', () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        // සියලුම ටැග්ස් පෙන්වීම
        hiddenTags.forEach(tag => {
          tag.classList.remove('hidden');
          // Smooth fade-in එකක් සඳහා
          tag.classList.add('animate-fade-in');
        });
        btn.querySelector('span')!.textContent = 'Show Less';
      } else {
        // නැවත මුල් තත්ත්වයට පත් කර Tags 12ක් පමණක් පෙන්වීම
        hiddenTags.forEach(tag => {
          tag.classList.add('hidden');
        });
        btn.querySelector('span')!.textContent = 'Show All Tags';
      }
    });
  }

  // Astro View Transitions සහ සාමාන්‍ය ලෝඩ් වීම් දෙකටම ගැළපීම (Strict SEO Fix)
  document.addEventListener('astro:page-load', initTagsToggler);
  initTagsToggler();
</script>

<style>
  /* ටැග්ස් එක පාරටම පාත් වෙද්දී ඇස් වලට ලස්සනට පෙනෙන්න කුඩා ඇනිමේෂන් එකක් */
  .animate-fade-in {
    animation: fadeIn 0.3s ease-in-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
