---
import { getSinglePage } from "@/lib/contentParser.astro";        
import dateFormat from "@/lib/utils/dateFormat";        
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";        
import { Image } from "astro:assets";        
import type { CollectionEntry } from "astro:content";        
import { BiCalendarEdit, BiCategoryAlt, BiPurchaseTagAlt } from "react-icons/bi";        
        
type Props = {        
  posts: CollectionEntry<"posts">[];        
  className?: string;        
  fluid?: boolean;        
};        
        
const authors = await getSinglePage("authors");        
const { className, posts, fluid } = Astro.props;        
        
// 🎯 GLOBAL HARVESTING SEO: පිටුවෙන් පිටුවට Tags වෙනස් වීම වැළැක්වීමට මුළු සයිට් එකේම පෝස්ට් ගෝලීයව එකතු කිරීම        
const allGlobalPosts = await getSinglePage("posts");        
const allTags = allGlobalPosts.flatMap((post) => post.data.tags || []);        
const uniqueTags = [...new Set(allTags)].filter(Boolean);        
---        
        
<div class={`w-full ${className} bg-[#010203]`}>        
  {/* 🚀 2026 ULTRA-MODERN RESPONSIVE CSS GRID — පේළියට 3 බැගින් ලස්සනට ලොකුවට හැඩගැසේ */}        
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 w-full">        
    {        
      posts.map((post, i: number) => (        
        <article class="flex flex-col justify-between bg-[#080a0f]/40 p-3 sm:p-4 rounded-xl border border-white/5 hover:border-white/10 transition-all duration-300 group">        
          
          {post.data.image && (        
            <a        
              href={`/blog/${post.id}/`}        
              class="w-full rounded-lg block overflow-hidden relative border border-white/10 aspect-[3/4] bg-[#050505]"        
            >        
              <Image        
                class="group-hover:scale-[1.03] transition duration-500 w-full h-full object-cover object-top"        
                src={post.data.image}        
                alt={`${post.data.title} - Sinhala Wal Katha`}        
                width={600}        
                height={800}        
                loading={i < 3 ? "eager" : "lazy"}        
                fetchpriority={i < 3 ? "high" : "low"}
                decoding="async"        
              />        
            </a>        
          )}        
                  
          {/* INFO ROW */}        
          <ul class="mt-3 mb-2 flex flex-wrap items-center text-[#F8F8FF]/90 text-[11px] sm:text-xs justify-between gap-1">        
            <li class="flex items-center">        
              <BiCategoryAlt className="mr-1 h-3.5 w-3.5 text-[#01AD9F]" />        
              <div class="flex flex-wrap gap-1">        
                {post.data.categories.slice(0, 1).map((category) => (        
                  <a        
                    href={`/categories/${slugify(category)}/`}        
                    class="hover:bg-[#01AD9F] hover:text-white transition-all font-black text-[10px] sm:text-xs bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF]"        
                  >        
                    {humanize(category)}
                  </a>        
                ))}        
              </div>        
            </li>        
            <li class="flex items-center font-bold text-[10px] sm:text-xs text-[#F8F8FF]/70">        
              <BiCalendarEdit className="mr-1 h-3.5 w-3.5 text-[#01AD9F]" />        
              {dateFormat(post.data.date!)}        
            </li>        
          </ul>        
        
          {/* POST TITLE */}        
          <h3 class="mb-2 line-clamp-2 leading-snug">        
            <a        
              href={`/blog/${post.id}/`}        
              class="block hover:text-[#01AD9F] transition duration-300 text-sm sm:text-base lg:text-lg font-black text-[#F8F8FF]"        
            >        
              {post.data.title}        
            </a>        
          </h3>        
        
          {/* EXCERPT TEXT */}        
          <p class="text-[#F8F8FF]/75 text-[11px] sm:text-sm line-clamp-2 mb-3 leading-relaxed">{plainify(post.body ?? "")}</p>        
        
          {/* AUTHOR & READ ROW */}        
          <div class="flex items-center justify-between border-t border-white/5 pt-3 mt-auto gap-2">        
            {authors        
              .filter((author) =>        
                post.data.authors        
                  .map((author) => slugify(author))        
                  .includes(slugify(author.data.title))        
              )        
              .slice(0, 1)        
              .map((author) => (        
                <a        
                  href={`/authors/${slugify(author.data.title)}/`}        
                  class="flex items-center hover:text-[#01AD9F] text-[11px] sm:text-xs font-bold text-[#F8F8FF] min-w-0 flex-shrink-1"        
                >        
                  {author.data.image && (        
                    <Image        
                      src={author.data.image}        
                      alt={author.data.title}        
                      height={28}        
                      width={28}        
                      class="mr-1.5 h-5 w-5 sm:h-6 sm:w-6 rounded-full object-cover flex-shrink-0 border border-white/20"        
                    />        
                  )}        
                  <span class="truncate">{author.data.title}</span>        
                </a>        
              ))}        
                      
            <a         
              href={`/blog/${post.id}/`}         
              class="text-[11px] sm:text-xs bg-[#01AD9F] text-white px-4 sm:px-6 py-1.5 rounded-full hover:bg-opacity-90 transition-all font-black whitespace-nowrap text-center"        
            >        
              Read Story
            </a>        
          </div>        
        </article>        
      ))        
    }        
  </div>        
        
  {/* 🏷️ Blogger Style Labels Section */}        
  {uniqueTags.length > 0 && (        
    <div class="mt-12 p-4 sm:p-6 bg-[#FFCC00] rounded-xl border border-[#E6B800]">        
      <div class="flex items-center gap-2 mb-4 border-b border-[#010203]/10 pb-2">        
        <BiPurchaseTagAlt className="text-[#010203] h-5 w-5" />        
        <h4 class="text-sm sm:text-base font-black text-[#010203]">Labels (ටැග්ස්)</h4>        
      </div>        
              
      <div class="relative flex flex-col">        
        <nav aria-label="Tags Cloud" class="transition-all duration-300 ease-in-out overflow-hidden max-h-[110px]" id="tags-toggle-container">        
          <ul class="flex flex-wrap gap-2 m-0 p-0 list-none">        
            {uniqueTags.map((tag, index) => (        
              <li class={`tag-item-wrap ${index >= 12 ? 'hidden-tag hidden' : ''}`}>        
                <a        
                  href={`/tags/${slugify(tag)}/`}        
                  rel="tag"        
                  class="text-[11px] sm:text-xs bg-[#010203] text-white font-black tracking-wide px-2.5 py-1.5 rounded-md border border-black hover:bg-[#01AD9F] hover:text-white transition-all shadow-sm flex items-center gap-0.5"        
                  title={`${tag} කතා සියල්ල මෙතනින් බලන්න`}        
                  aria-label={`View posts tagged with ${tag}`}        
                >        
                  <span class="opacity-50 text-white font-normal">#</span>{humanize(tag)}        
                </a>        
              </li>        
            ))}        
          </ul>        
        </nav>        
        
        {uniqueTags.length > 12 && (        
          <div class="mt-5 flex justify-center w-full">        
            <button        
              id="btn-toggle-tags"        
              type="button"        
              class="text-[11px] sm:text-xs bg-[#010203] text-white font-black px-5 py-2 rounded-full shadow-md hover:bg-[#01AD9F] transition-all flex items-center gap-1 cursor-pointer z-10"        
            >        
              <span>Show All Tags</span>        
            </button>        
          </div>        
        )}        
      </div>        
    </div>        
  )}        
</div>        
        
{/* SMOOTH TRANSITION SCRIPT (ASTRO COMPATIBLE) */}        
<script>        
  function initTagsToggler() {        
    const btn = document.getElementById('btn-toggle-tags');        
    const container = document.getElementById('tags-toggle-container');        
    const hiddenTags = document.querySelectorAll('.hidden-tag');        
            
    if (!btn || !container || hiddenTags.length === 0) return;        
            
    let isOpen = false;        
            
    btn.addEventListener('click', () => {        
      isOpen = !isOpen;        
              
      if (isOpen) {        
        container.style.maxHeight = '2000px';        
        hiddenTags.forEach(tag => tag.classList.remove('hidden'));        
        btn.querySelector('span')!.textContent = 'Show Less';        
      } else {        
        container.style.maxHeight = '110px';        
        btn.querySelector('span')!.textContent = 'Show All Tags';        
                
        setTimeout(() => {        
          if (!isOpen) {        
            hiddenTags.forEach(tag => tag.classList.add('hidden'));        
          }        
        }, 300);        
      }        
    });        
  }        
        
  document.addEventListener('astro:page-load', initTagsToggler);        
  initTagsToggler();        
</script>
