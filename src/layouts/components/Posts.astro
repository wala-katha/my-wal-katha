---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt, BiPurchaseTagAlt } from "react-icons/bi";

// ✅ Props (ONLY data coming from parent - no heavy SSR here)
type Props = {
  posts: CollectionEntry<"posts">[];
  authors: CollectionEntry<"authors">[];
  className?: string;
  fluid?: boolean;
};

const { className = "", posts, authors } = Astro.props;

/**
 * 🚀 PERFORMANCE FIX:
 * Global posts fetch REMOVED
 * Tags computed ONLY from current page posts (not entire site)
 */
const allTags = posts.flatMap((p) => p.data.tags ?? []);
const uniqueTags = [...new Set(allTags)].filter(Boolean);

// ⚡ Author map for O(1) lookup instead of repeated filter loops
const authorMap = new Map(
  authors.map((a) => [slugify(a.data.title), a])
);
---

<div class={`w-full ${className} bg-[#010203]`}>
  <!-- POSTS GRID -->
  <div class="row gy-4 gx-2 sm:gx-4">
    {posts.map((post, i) => {
      const postAuthors = (post.data.authors ?? [])
        .map((a) => authorMap.get(slugify(a)))
        .filter(Boolean);

      return (
        <div class="col-4 flex flex-col justify-between">
          {post.data.image && (
            <a
              href={`/blog/${post.id}/`}
              class="group block overflow-hidden rounded-lg border border-white/10 relative"
              style="aspect-ratio: 2 / 3;"
            >
              <Image
                src={post.data.image}
                alt={post.data.title}
                width={500}
                height={750}
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              />
            </a>
          )}

          {/* META */}
          <ul class="mt-2 mb-1 flex flex-wrap items-center justify-between text-[#F8F8FF]/90 text-[10px] sm:text-sm">
            <li class="flex items-center gap-1">
              <BiCategoryAlt className="h-4 w-4 text-[#01AD9F]" />
              {post.data.categories?.slice(0, 1).map((category) => (
                <a
                  href={`/categories/${slugify(category)}/`}
                  class="bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF] font-bold text-[10px]"
                >
                  {humanize(category)}
                </a>
              ))}
            </li>

            <li class="hidden xs:flex items-center gap-1 text-[#F8F8FF]/70">
              <BiCalendarEdit className="h-4 w-4 text-[#01AD9F]" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>

          {/* TITLE */}
          <h3 class="mb-1 line-clamp-2">
            <a
              href={`/blog/${post.id}/`}
              class="text-[#F8F8FF] font-black text-xs sm:text-base hover:text-primary transition"
            >
              {post.data.title}
            </a>
          </h3>

          {/* EXCERPT */}
          <p class="text-[#F8F8FF]/70 text-[11px] sm:text-sm line-clamp-2">
            {plainify(post.body ?? "")}
          </p>

          {/* AUTHOR + CTA */}
          <div class="flex items-center justify-between border-t border-white/10 pt-2 mt-auto gap-2">
            {postAuthors.slice(0, 1).map((author) => (
              <a
                href={`/authors/${slugify(author.data.title)}/`}
                class="flex items-center gap-1 text-[#F8F8FF] text-xs font-bold"
              >
                {author.data.image && (
                  <Image
                    src={author.data.image}
                    alt={author.data.title}
                    width={24}
                    height={24}
                    class="h-5 w-5 rounded-full object-cover"
                  />
                )}
                <span class="truncate">{author.data.title}</span>
              </a>
            ))}

            <a
              href={`/blog/${post.id}/`}
              class="bg-[#01AD9F] text-white text-[10px] px-4 py-1 rounded-full font-black hover:opacity-90 transition"
            >
              Read
            </a>
          </div>
        </div>
      );
    })}
  </div>

  {/* TAGS SECTION */}
  {uniqueTags.length > 0 && (
    <div class="mt-10 p-5 bg-[#FFCC00] rounded-xl border border-[#E6B800]">
      <div class="flex items-center gap-2 mb-3 border-b border-black/10 pb-2">
        <BiPurchaseTagAlt className="text-[#010203] h-5 w-5" />
        <h4 class="font-black text-[#010203]">Labels</h4>
      </div>

      <nav aria-label="Tags">
        <ul class="flex flex-wrap gap-2">
          {uniqueTags.slice(0, 20).map((tag) => (
            <li>
              <a
                href={`/tags/${slugify(tag)}/`}
                class="bg-[#010203] text-white text-xs font-bold px-3 py-1 rounded hover:bg-[#01AD9F]"
              >
                #{humanize(tag)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</div>
