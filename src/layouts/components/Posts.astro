---
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt, BiPurchaseTagAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;

// ✅ FIX 4: allGlobalPosts redundant fetch ඉවත් කළා
// PROBLEM: getSinglePage("posts") props එකෙන් ලැබෙන posts ම නැවත fetch කළා
// FIX: props posts use කරයි — tags ද props posts වලින් ගනී
// NOTE: index.astro, page/[slug].astro, categories/[category].astro
//       සියල්ල posts prop pass කරනවා — safe
const allTags = posts.flatMap((post) => post.data.tags || []);
const uniqueTags = [...new Set(allTags)].filter(Boolean);
---

{/* ✅ SEMANTIC SEO: posts list structured as semantic <ul> grid */}
<div class={`w-full mx-auto max-w-[1450px] px-2 sm:px-4 ${className ?? ''} bg-[#010203]`}>
  <ul class={`row gy-5 gx-2 sm:gx-4 m-0 p-0 list-none ${posts.length === 1 ? "justify-center" : ""}`}>
    {
      posts.map((post, i: number) => {

        // ✅ FIX 10: Author lookup — safe slugify both sides
        const postAuthor = authors.find((author) =>
          post.data.authors
            .map((a: string) => slugify(a))
            .includes(slugify(author.data.title))
        );

        // ✅ FIX 9: dateFormat returns object with toString() — safe string conversion
        const formattedDate = post.data.date ? dateFormat(post.data.date).toString() : null;
        const isoDate = post.data.date ? new Date(post.data.date).toISOString() : undefined;

        // ✅ FIX 7: Safe body text — crash prevention
        const bodyText = typeof post.body === "string" ? plainify(post.body.slice(0, 200)) : "";

        return (
          <li class="col-6 flex flex-col justify-between">
            <article
              class="w-full h-full flex flex-col justify-between"
              itemscope
              itemtype="https://schema.org/Article"
            >
              {/* ✅ FIX 1 & 2: Post image — responsive sizes corrected
                  PROBLEM: 
                  - Image served at 1600×2495px, displayed at 434×677px
                  - sizes="50vw" incorrect — container is max-w-[1000px]
                  - 50vw on 1440px screen = 720px, but actual display ~480px
                  
                  FIX:
                  - width=600 height=800 (3:4 ratio) — matches aspect-ratio: 3/4
                  - sizes: accurate viewport breakpoints for 2-column grid
                    - Mobile (<640px): 2 columns in ~390px viewport = ~185px each
                    - Tablet (<768px): 2 columns in ~750px viewport = ~360px each  
                    - Desktop (<1024px): 2 columns in ~1000px max = ~480px each
                    - Large: fixed ~480px (container 1000px ÷ 2)
                  - Astro Image component handles srcset generation automatically
                    with these width/sizes values
                  
                  IMPACT: ~1,924 KiB → ~150 KiB per image (estimated)
              */}
              {post.data.image && (
                <a
                  href={`/blog/${post.id}/`}
                  class="rounded-xl block hover:text-primary overflow-hidden group relative border border-white/10 shadow-lg transition duration-300 w-full"
                  style="aspect-ratio: 3 / 4;"
                  title={`${post.data.title} සම්පූර්ණ කතාව කියවන්න`}
                  aria-label={`Read: ${post.data.title}`}
                  itemprop="url"
                >
                  <Image
                    class="group-hover:scale-[1.03] transition duration-500 w-full h-full object-cover object-top"
                    src={post.data.image}
                    alt={`${post.data.title} - Sinhala Wal Katha`}
                    width={600}
                    height={800}
                    sizes="(max-width: 480px) 185px, (max-width: 768px) 360px, (max-width: 1024px) 480px, 480px"
                    loading={i < 2 ? "eager" : "lazy"}
                    decoding={i < 2 ? "sync" : "async"}
                    fetchpriority={i === 0 ? "high" : "auto"}
                    itemprop="image"
                  />
                  {/* Gradient overlay */}
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"
                    aria-hidden="true"
                  ></div>
                </a>
              )}

              {/* ✅ Schema.org meta — hidden, SEO only */}
              {post.data.title && <meta itemprop="name" content={post.data.title} />}
              {post.data.description && <meta itemprop="description" content={post.data.description} />}

              {/* Meta details */}
              <ul class="mt-3 mb-1 flex flex-wrap items-center text-[#F8F8FF]/90 text-[10px] sm:text-xs justify-between gap-1 p-0 list-none">
                <li class="flex items-center flex-wrap">
                  <BiCategoryAlt className="mr-0.5 h-3.5 w-3.5 sm:h-[15px] sm:w-[15px] text-[#01AD9F]" />
                  <ul class="inline-flex p-0 list-none">
                    {post.data.categories.slice(0, 1).map((category: string) => (
                      <li class="inline-block">
                        <a
                          href={`/categories/${slugify(category)}/`}
                          class="hover:text-primary font-black text-[9px] sm:text-[11px] bg-white/10 px-1.5 sm:px-2 py-0.5 rounded text-[#F8F8FF]"
                          itemprop="articleSection"
                        >
                          {humanize(category)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>

                {/* ✅ FIX 9: dateFormat toString() explicit call */}
                {formattedDate && (
                  <li class="hidden xs:flex items-center flex-wrap font-bold text-[9px] sm:text-[11px] text-[#F8F8FF]/70">
                    <BiCalendarEdit className="mr-0.5 h-3.5 w-3.5 sm:h-4 sm:w-4 text-[#01AD9F]" />
                    <time
                      dateTime={isoDate}
                      itemprop="datePublished"
                    >
                      {formattedDate}
                    </time>
                  </li>
                )}
              </ul>

              {/* ✅ Heading hierarchy — h3 correct here (index.astro h1 → Posts section h2 → post title h3) */}
              <h3 class="mb-1.5 line-clamp-2 leading-tight" itemprop="headline">
                <a
                  href={`/blog/${post.id}/`}
                  class="block hover:text-primary transition duration-300 text-[12px] sm:text-base lg:text-xl font-black text-[#F8F8FF]"
                  title={post.data.title}
                >
                  {post.data.title}
                </a>
              </h3>

              {/* ✅ FIX 7: Safe body text with crash prevention */}
              {bodyText && (
                <p
                  class="text-[#F8F8FF]/70 text-[10px] sm:text-sm line-clamp-2 mb-2 leading-snug"
                  itemprop="abstract"
                >
                  {bodyText}
                </p>
              )}

              {/* Author row & Read button */}
              <div class="flex items-center justify-between border-t border-white/10 pt-2 sm:pt-3 mt-auto gap-2">
                {postAuthor && (
                  <a
                    href={`/authors/${slugify(postAuthor.data.title)}/`}
                    class="flex items-center hover:text-primary text-[9px] sm:text-xs font-bold text-[#F8F8FF] min-w-0 flex-shrink-1"
                    title={`${postAuthor.data.title} ලේඛකයාගේ සියලුම කතා`}
                    itemprop="author"
                    itemscope
                    itemtype="https://schema.org/Person"
                  >
                    {postAuthor.data.image && (
                      <Image
                        src={postAuthor.data.image}
                        alt={postAuthor.data.title}
                        width={24}
                        height={24}
                        loading="lazy"
                        decoding="async"
                        class="mr-1 h-4 w-4 sm:h-5 sm:w-5 rounded-full object-cover flex-shrink-0 border border-white/20"
                      />
                    )}
                    <span class="truncate" itemprop="name">{postAuthor.data.title}</span>
                  </a>
                )}

                {/* ✅ FIX 3: "Read" button contrast fix
                    PROBLEM: bg-[#01AD9F] text-white — contrast ratio ~2.8:1 (WCAG AA fail, needs 4.5:1)
                    
                    WCAG AA contrast check:
                    - #01AD9F on white = 2.85:1 ❌
                    - #01AD9F on #010203 dark bg = passes for large text only
                    - text-white (#ffffff) on #01AD9F = 2.85:1 ❌
                    
                    FIX: text-[#010203] (near black) on bg-[#01AD9F]
                    - #010203 on #01AD9F = 7.23:1 ✅ WCAG AAA passes
                    - Same visual appearance, just text color changed dark→black
                    
                    ADDITIONAL: min-w touch target ensure — py-2 (8px+8px=16px height)
                    Added min-h for touch target compliance
                */}
                <a
                  href={`/blog/${post.id}/`}
                  class="text-[9px] sm:text-xs bg-[#01AD9F] text-[#010203] px-3 sm:px-5 py-1.5 rounded-full hover:bg-[#018f84] transition-all font-black whitespace-nowrap flex-grow text-center max-w-[90px] min-h-[32px] flex items-center justify-center"
                  aria-label={`Read full story: ${post.data.title}`}
                >
                  Read
                </a>
              </div>
            </article>
          </li>
        );
      })
    }
  </ul>

  {/* ✅ Tags section */}
  {uniqueTags.length > 0 && (
    <div class="mt-16 p-4 sm:p-6 bg-[#FFCC00] rounded-xl border border-[#E6B800]">
      <div class="flex items-center gap-2 mb-4 border-b border-[#010203]/10 pb-2">
        <BiPurchaseTagAlt className="text-[#010203] h-5 w-5" aria-hidden="true" />
        <h2 class="text-sm sm:text-base font-black text-[#010203] m-0">Labels (ටැග්ස්)</h2>
      </div>

      <div class="relative flex flex-col">
        {/* ✅ FIX 6: Tags toggle — SSR safe
            PROBLEM: index >= 12 hidden class JS-only — SSR render time all tags visible briefly
            FIX: First 12 always visible, rest hidden via CSS class set at SSR time
            JS only toggles — no flash of all tags
        */}
        <nav
          aria-label="Tags Cloud"
          class="transition-all duration-300 ease-in-out overflow-hidden"
          style="max-height: 110px;"
          id="tags-toggle-container"
        >
          <ul class="flex flex-wrap gap-2 m-0 p-0 list-none">
            {uniqueTags.map((tag: string, index: number) => (
              <li class={index >= 12 ? "hidden-tag" : ""} style={index >= 12 ? "display:none;" : ""}>
                <a
                  href={`/tags/${slugify(tag)}/`}
                  rel="tag"
                  class="text-[11px] sm:text-xs bg-[#010203] text-white font-black tracking-wide px-2.5 py-1.5 rounded-md border border-black hover:bg-[#01AD9F] hover:text-white transition-all shadow-sm flex items-center gap-0.5"
                  title={`${tag} කතා සියල්ල`}
                  aria-label={`View posts tagged: ${tag}`}
                >
                  <span class="opacity-50 text-white font-normal" aria-hidden="true">#</span>
                  {humanize(tag)}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        {uniqueTags.length > 12 && (
          <div class="mt-5 flex justify-center w-full">
            <button
              id="btn-toggle-tags"
              type="button"
              aria-expanded="false"
              aria-controls="tags-toggle-container"
              class="text-[11px] sm:text-xs bg-[#010203] text-white font-black px-5 py-2 rounded-full shadow-md hover:bg-[#01AD9F] transition-all flex items-center gap-1 cursor-pointer"
            >
              <span id="btn-toggle-tags-text">Show All Tags</span>
            </button>
          </div>
        )}
      </div>
    </div>
  )}
</div>

<script>
  function initTagsToggler() {
    const btn = document.getElementById('btn-toggle-tags');
    const container = document.getElementById('tags-toggle-container');
    const hiddenTags = document.querySelectorAll<HTMLElement>('.hidden-tag');
    const btnText = document.getElementById('btn-toggle-tags-text');

    if (!btn || !container) return;

    // ✅ FIX 6: SSR-safe — hidden tags already hidden via inline style
    // JS only shows/hides on toggle
    let isOpen = false;

    btn.addEventListener('click', () => {
      isOpen = !isOpen;

      if (isOpen) {
        container.style.maxHeight = '2000px';
        hiddenTags.forEach(tag => {
          tag.style.display = '';
        });
        if (btnText) btnText.textContent = 'Show Less';
        btn.setAttribute('aria-expanded', 'true');
      } else {
        container.style.maxHeight = '110px';
        if (btnText) btnText.textContent = 'Show All Tags';
        btn.setAttribute('aria-expanded', 'false');

        // ✅ Wait for CSS transition before hiding
        setTimeout(() => {
          if (!isOpen) {
            hiddenTags.forEach(tag => {
              tag.style.display = 'none';
            });
          }
        }, 300);
      }
    });
  }

  // ✅ Both Astro View Transitions and direct load
  document.addEventListener('astro:page-load', initTagsToggler);
</script>
