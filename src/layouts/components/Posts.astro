---
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;
---

<div
  class={`row gy-4 gx-2 md:gx-4 ${className} ${posts.length == 1 ? "justify-center" : ""} `}
>
  {
    posts.map((post, i: number) => (
      // 100% FIX: Mobile, Tablet, Desktop කියන සියලුම තිර වලදී එක පෙළට 3 බැගින් පෙන්වීමට col-4 පමණක්ම භාවිතා කළා
      <div class="col-4 flex flex-col justify-between">
        {post.data.image && (
          <a
            href={`/blog/${post.id}/`}
            class="rounded block hover:text-primary overflow-hidden group relative bg-gray-50 dark:bg-darkmode-theme-light"
          >
            {/* 100% FIX: පින්තූරය දශමයක්වත් Crop නොවීම සඳහා object-contain භාවිතා කර උස සහ පළල ස්වයංක්‍රීයව හැඩගැස්සුවා */}
            <Image
              class="group-hover:scale-[1.03] transition duration-300 w-full h-auto object-contain max-h-[150px] sm:max-h-[300px] lg:max-h-[450px]"
              src={post.data.image}
              alt={post.data.title}
              width={445}
              height={665}
              loading={i < 3 ? "eager" : "lazy"}
              decoding="async"
            />
          </a>
        )}
        
        {/* INFO ROW: මොබයිල් එකේදී අකුරු ඔටෝ කුඩා වන පරිදි සකසා ඇත */}
        <ul class="mt-2 mb-1 flex flex-wrap items-center text-text justify-between text-[9px] sm:text-xs md:text-sm">
          <li class="flex items-center flex-wrap">
            <BiCategoryAlt className="mr-0.5 h-[10px] w-[10px] sm:h-[14px] sm:w-[14px] text-gray-600" />
            <ul>
              {post.data.categories.slice(0, 1).map((category) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}/`}
                    class="hover:text-primary font-bold bg-gray-100 dark:bg-darkmode-theme-light px-1 py-0.5 rounded text-[8px] sm:text-xs"
                  >
                    {humanize(category)}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <li class="flex items-center flex-wrap font-medium text-gray-500 text-[8px] sm:text-xs">
            <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4" />
            {dateFormat(post.data.date!)}
          </li>
        </ul>

        {/* POST TITLE: තිරයේ ප්‍රමාණයට අනුව text-xs සිට text-base දක්වා ඔටෝ වෙනස් වේ */}
        <h3 class="mb-1 line-clamp-2 text-[11px] sm:text-sm md:text-base font-bold leading-tight">
          <a
            href={`/blog/${post.id}/`}
            class="block hover:text-primary transition duration-300"
          >
            {post.data.title}
          </a>
        </h3>

        {/* POST SNIPPET: කිසිවක් නොකපා පේළි 2කට සීමා කර පිරිසිදුව තබා ඇත */}
        <p class="text-text text-[9px] sm:text-xs md:text-sm line-clamp-2 mb-2 leading-normal">
          {plainify(post.body ?? "")}
        </p>

        {/* AUTHOR & READ MORE CONTAINER */}
        <div class="flex items-center justify-between border-t border-gray-100 pt-2 mt-auto gap-1">
          {authors
            .filter((author) =>
              post.data.authors
                .map((author) => slugify(author))
                .includes(slugify(author.data.title))
            )
            .slice(0, 1)
            .map((author) => (
              <a
                href={`/authors/${slugify(author.data.title)}/`}
                class="flex items-center hover:text-primary text-[8px] sm:text-xs font-medium min-w-0"
              >
                {author.data.image && (
                  <Image
                    src={author.data.image}
                    alt={author.data.title}
                    height={20}
                    width={20}
                    class="mr-1 h-3 w-3 sm:h-5 sm:w-5 rounded-full object-cover flex-shrink-0"
                  />
                )}
                <span class="truncate">{author.data.title}</span>
              </a>
            ))}
            
          {/* READ MORE BUTTON: මොබයිල් තිරයට අනුව Padding සහ අකුරු ඔටෝ කුඩා වේ */}
          <a 
            href={`/blog/${post.id}/`} 
            class="text-[8px] sm:text-xs bg-primary text-white px-1.5 py-0.5 sm:px-3 sm:py-1.5 rounded-full hover:bg-opacity-90 transition-all font-medium whitespace-nowrap"
          >
            Read more
          </a>
        </div>
      </div>
    ))
  }
</div>
