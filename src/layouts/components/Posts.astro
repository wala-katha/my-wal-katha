---
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const authors = await getSinglePage("authors");
const { className, posts, fluid } = Astro.props;
---

{/* 100% FIX: Bootstrap පටලැවිල්ල අයින් කර පිරිසිදු Tailwind CSS Grid එකක් එකතු කළා */}
<div
  class={`grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 w-full ${className}`}
>
  {
    posts.map((post, i: number) => (
      <div class="w-full flex flex-col bg-white dark:bg-darkmode-theme-light rounded-xl overflow-hidden p-3 shadow-sm hover:shadow-md transition-shadow duration-300">
        {post.data.image && (
          <a
            href={`/blog/${post.id}/`}
            class="rounded-lg block hover:text-primary overflow-hidden group relative w-full"
            style="aspect-ratio: 2 / 3;" /* BOOK COVER LOOK: බ්ලොගර් සයිට් එකේ වගේම දිගටි සිරස් පෙනුම */
          >
            <Image
              class="group-hover:scale-[1.04] transition duration-300 w-full h-full object-cover"
              src={post.data.image}
              alt={post.data.title}
              width={445}
              height={665}
              loading={i < 3 ? "eager" : "lazy"} /* SEO LCP Optimization */
              decoding="async"
            />
          </a>
        )}
        
        {/* INFO ROW: කැටගරි සහ දිනය පෝස්ට් එකට ඉහළින් පෙන්වීම */}
        <ul class="mt-4 mb-2 flex flex-wrap items-center text-text text-sm justify-between w-full list-none padding-0">
          <li class="flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[16px] w-[16px] text-gray-600" />
            <ul class="list-none flex p-0 m-0">
              {post.data.categories.slice(0, 1).map((category) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}/`}
                    class="hover:text-primary font-bold text-xs bg-gray-100 dark:bg-darkmode-body px-2 py-0.5 rounded"
                  >
                    {humanize(category)}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <li class="flex items-center flex-wrap font-medium text-xs text-gray-500">
            <BiCalendarEdit className="mr-1 h-4 w-4" />
            {dateFormat(post.data.date!)}
          </li>
        </ul>

        {/* POST TITLE */}
        <h3 class="h5 mb-2 line-clamp-2 w-full">
          <a
            href={`/blog/${post.id}/`}
            class="block hover:text-primary transition duration-300 text-base font-bold text-gray-900 dark:text-white"
          >
            {post.data.title}
          </a>
        </h3>

        {/* POST SNIPPET */}
        <p class="text-text text-sm line-clamp-2 mb-4 w-full">{plainify(post.body ?? "")}</p>

        {/* AUTHOR & READ MORE CONTAINER */}
        <div class="flex items-center justify-between border-t border-gray-100 dark:border-gray-800 pt-3 mt-auto w-full">
          {authors
            .filter((author) =>
              post.data.authors
                .map((author) => slugify(author))
                .includes(slugify(author.data.title))
            )
            .slice(0, 1)
            .map((author) => (
              <a
                href={`/authors/${slugify(author.data.title)}/`}
                class="flex items-center hover:text-primary text-xs font-medium"
              >
                {author.data.image && (
                  <Image
                    src={author.data.image}
                    alt={author.data.title}
                    height={30}
                    width={30}
                    class="mr-1.5 h-5 w-5 rounded-full object-cover"
                  />
                )}
                <span>{author.data.title}</span>
              </a>
            ))}
            
          <a 
            href={`/blog/${post.id}/`} 
            class="text-xs bg-primary text-white px-3 py-1.5 rounded-full hover:bg-opacity-90 transition-all font-medium"
          >
            Read more
          </a>
        </div>
      </div>
    ))
  }
</div>
