---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
};
const { posts } = Astro.props;
---

{/* 👑 3-WAY PREMIUM GOLD GRADIENT BACKGROUND FIX:
    සුදු පැහැයෙන් පටන් ගෙන (transparent/white), මැදදී තද දිලිසෙන දඹරත්තරන් පැහැයට හැරී (#D4AF37), 
    නැවතත් පතුලට යද්දී සුදු පැහැයටම (transparent/white) මුසුවන සුපිරි පසුබිම. */}
<div class="w-full bg-gradient-to-b from-transparent via-[#D4AF37]/35 to-transparent dark:from-transparent dark:via-[#B8860B]/25 dark:to-transparent p-4 sm:p-6 rounded-2xl transition-all duration-300">
  
  <div class="row gy-4 gx-2 sm:gx-4 justify-center">
    {
      posts.map((post) => (
        /* 🎯 UI & SEO GRID FIX: මොබයිල්, ටැබ්, ඩෙස්ක්ටොප් හැම එකකදීම එක පේළියට පෝස්ට් 3 බැගින් පේළි දෙකකට පෝස්ට් 6ක් හැඩගැස්වීම */
        <div class="col-4 flex flex-col justify-between group mb-4 text-center">
          {post.data.image && (
            <a
              href={`/blog/${post.id}/`} /* ⚠️ FIXED: නිවැරදි Astro Content Layer URL එක */
              class="rounded-lg block overflow-hidden group relative bg-gray-900 transition-all duration-300 mx-auto w-full"
              style="aspect-ratio: 3 / 4;" /* ⚡ FIX: උස දශමයක් අඩු කර කාඩ් එක වඩාත් පිළිවෙළ කිරීමට Ratio එක 3:4 කළා */
            >
              
              {/* 🔄 ANIMATED RUNNING WHITE BORDER EFFECT: 
                  පින්තූරය වටා නොනවත්වාම දුවන සුදු පැහැති ආලෝක ඉරේ ඇනිමේෂන් ලේයර් එක */}
              <div 
                class="absolute inset-0 pointer-events-none rounded-lg z-10 before:absolute before:inset-[-200%] before:bg-[conic-gradient(from_0deg,transparent_40%,#ffffff_50%,transparent_60%)] before:animate-[spin_4s_linear_infinite]"
                style="mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); mask-composite: xor; -webkit-mask-composite: xor; padding: 2px;"
              ></div>

              {/* 👑 IMAGE COMPONENT: ඇනිමේෂන් එක පිරිසිදුව පෙනීම සඳහා මෙහි පැරණි රන්වන් බෝඩරය ඉවත් කර පින්තූරය සකස් කළා */}
              <Image
                class="w-full h-full object-contain rounded-lg group-hover:scale-[1.03] transition-all duration-300 shadow-[0_0_1px_rgba(0,0,0,0)] group-hover:shadow-[0_0_15px_rgba(255,255,255,0.6)]"
                src={post.data.image}
                alt={post.data.title}
                width={500}
                height={666} /* ⚡ Ratio එකට ගැළපෙන සේ උස ප්‍රමාණය නූලටම වෙනස් කළා */
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          
          {/* INFO ROW: මැදට පෙළගස්වා මොබයිල් තිර වලට ගැළපෙන සේ මෙටා ඩේටා අකුරු ලස්සනට කුඩා කළා */}
          <ul class="mt-2 mb-1 flex flex-wrap items-center text-text text-[10px] sm:text-xs justify-center gap-x-2">
            <li class="flex items-center flex-wrap">
              <BiCategoryAlt className="mr-0.5 h-3 w-3 sm:h-[14px] sm:w-[14px] text-gray-600" />
              <ul>
                {post.data.categories.slice(0, 1).map((category: string) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}/`}
                      class="hover:text-primary font-bold text-[9px] sm:text-xs bg-gray-100 dark:bg-darkmode-theme-light px-1 sm:px-2 py-0.5 rounded"
                    >
                      {humanize(category)}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
            <li class="hidden xs:flex items-center flex-wrap font-medium text-[9px] sm:text-xs text-gray-500">
              <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>

          {/* POST TITLE: text-center සහ mx-auto මඟින් මාතෘකාවේ දෙවැනි පේළිය පවා හරි මැදටම සකස් කරන ලදී */}
          <h3 class="mb-1 line-clamp-2 leading-tight text-center mx-auto w-full">
            <a
              href={`/blog/${post.id}/`}
              class="block hover:text-primary transition duration-300 text-[11px] sm:text-base font-bold text-dark dark:text-darkmode-text text-center"
            >
              {post.data.title}
            </a>
          </h3>
        </div>
      )
    })
  }
  </div>

</div>

{/* ⚡ SEO LIGHTWEIGHT ANIMATION KEYFRAME INJECTION:
    Tailwind ඇතුළත බාහිරව custom animation එකක් ලෝඩ් නොකර inline keyframe එකක් ලෙස ඇතුළත් කළ නිසා වේගය 100% ආරක්ෂා වේ. */}
<style is:inline>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
