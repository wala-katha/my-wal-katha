---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
};
const { posts } = Astro.props;
---

{/* 👑 CLEAN RICH BLACK INNER WRAPPER:
    පිටත ප්‍රධාන මවු සෙක්ෂන් එකෙන් කළු ➔ කොළ ➔ කළු ග්‍රේඩියන්ට් එක පාලනය වන බැවින්, 
    මෙම ඇතුළත කොටස කිසිදු අමතර පසුබිමකින් තොරව පිරිසිදුව නිශ්චලව තබා ඇත. */}
<div class="w-full p-4 sm:p-6 transition-all duration-300">
  
  <div class="row gy-4 gx-2 sm:gx-4 justify-center">
    {
      posts.map((post) => (
        /* 🎯 UI & SEO GRID FIX: මොබයිල්, ටැබ්, ඩෙස්ක්ටොප් හැම එකකදීම එක පේළියට පෝස්ට් 3 බැගින් පේළි දෙකකට පෝස්ට් 6ක් හැඩගැස්වීම */
        <div class="col-4 flex flex-col justify-between group mb-4 text-center">
          {post.data.image && (
            <a
              href={`/blog/${post.id}/`} /* ⚠️ FIXED: නිවැරදි Astro Content Layer URL එක */
              class="rounded-lg block overflow-hidden group relative bg-[#010203] mx-auto w-full"
              style="aspect-ratio: 3 / 4;" /* ⚡ FIX: උස දශමයක් අඩු කළ 3:4 Ratio එක */
            >
              {/* 👑 CLEAN & STATIC FRAME: කැරකෙන ඇනිමේෂන් සියල්ල ඉවත් කර, පින්තූරය වටා ස්ථාවර පිරිසිදු සුදු බෝඩර් එකක් පමණක් යෙදීම */}
              <Image
                class="w-full h-full object-contain rounded-lg border border-white/20 group-hover:border-white transition-all duration-300 relative z-0"
                src={post.data.image}
                alt={post.data.title}
                width={500}
                height={666} /* ⚡ Ratio එකට ගැළපෙන සේ උස ප්‍රමාණය */
                loading="lazy"
                decoding="async"
              />
            </a>
          )}
          
          {/* INFO ROW: කළු පසුබිමට කැපී පෙනෙන සේ මෙටා ඩේටා සහ අයිකන පිරිසිදු සුදු පැහැයට හැරවීම */}
          <ul class="mt-2 mb-1 flex flex-wrap items-center text-white/90 text-[10px] sm:text-xs justify-center gap-x-2">
            <li class="flex items-center flex-wrap">
              <BiCategoryAlt className="mr-0.5 h-3 w-3 sm:h-[14px] sm:w-[14px] text-[#01AD9F]" />
              <ul>
                {post.data.categories.slice(0, 1).map((category: string) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}/`}
                      class="hover:text-primary font-black text-[9px] sm:text-xs bg-white/10 px-1 sm:px-2 py-0.5 rounded text-white"
                    >
                      {humanize(category)}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
            <li class="hidden xs:flex items-center flex-wrap font-bold text-[9px] sm:text-xs text-white/80">
              <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4 text-[#01AD9F]" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>

          {/* POST TITLE: කළු පසුබිම මත උපරිමයෙන්ම පෙනීමට text-white සහ font-black යෙදීම */}
          <h3 class="mb-1 line-clamp-2 leading-tight text-center mx-auto w-full">
            <a
              href={`/blog/${post.id}/`}
              class="block hover:text-primary transition duration-300 text-[11px] sm:text-base font-black text-white text-center drop-shadow-sm"
            >
              {post.data.title}
            </a>
          </h3>
        </div>
      ))
    }
  </div>

</div>
