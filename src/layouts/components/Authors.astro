---
import { getOptimizedImage } from "@/lib/imageRegistry";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BsArrowRightCircle } from "react-icons/bs";

type Props = {
  authors: CollectionEntry<"authors">[];
};
const { authors } = Astro.props;
---

<div class="row justify-center gy-4">
  {
    authors.map((author) => {
      // ✅ IMAGE OPTIMIZATION: registry lookup
      // Registry hit → Astro <Image> optimized (Sharp compress/resize/srcset)
      // Registry miss → fallback raw <img> (site crash නොවේ)
      const optimizedImage = getOptimizedImage(author.data.image);

      return (
        <div 
          class="col-12 sm:col-6 md:col-4 flex"
          itemscope 
          itemtype="https://schema.org/Person"
        >
          <div class="w-full bg-white/5 border border-white/10 rounded-2xl p-6 flex flex-col items-center text-center transition-all duration-300 hover:border-white/30 hover:bg-white/10 group">
            
            {author.data.image && (
              <div class="mb-4 relative overflow-hidden rounded-full border-2 border-white/20 group-hover:border-[#01AD9F] transition-all duration-300 w-[120px] h-[120px]">
                {optimizedImage ? (
                  // ✅ OPTIMIZED: src/assets/ image → Sharp srcset + WebP
                  <Image
                    src={optimizedImage}
                    alt={author.data.title}
                    height={120}
                    width={120}
                    quality={80}
                    format="webp"
                    itemprop="image"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                ) : (
                  // ✅ FALLBACK: public/ image — unoptimized නමුත් site break නොවේ
                  <img
                    src={author.data.image}
                    alt={author.data.title}
                    height={120}
                    width={120}
                    itemprop="image"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover"
                  />
                )}
              </div>
            )}

            <h3 class="h5 mt-4 mb-2">
              <a
                href={`/authors/${author.id}/`}
                itemprop="url"
                class="block text-[#F8F8FF] hover:text-[#01AD9F] transition duration-200 font-black"
              >
                <span itemprop="name">{author.data.title}</span>
              </a>
            </h3>

            {author.body && (
              <p 
                class="text-[#F8F8FF]/70 text-sm mb-6 line-clamp-2 leading-relaxed flex-grow" 
                itemprop="description" 
                set:text={markdownify(author.body.slice(0, 100))} 
              />
            )}

            <a
              href={`/authors/${author.id}/`}
              class="inline-flex items-center justify-center w-full px-4 py-2 text-xs font-black text-white bg-[#01AD9F] rounded-xl transition duration-300 hover:bg-opacity-90 gap-2 shadow-sm"
              aria-label={`Read more about ${author.data.title}`}
            >
              Read Profile <BsArrowRightCircle className="inline text-base" />
            </a>
            
          </div>
        </div>
      );
    })
  }
</div>
