---
import Logo from "@/components/Logo.astro";
import menu from "@/config/menu.json";
import { IoSearch } from "react-icons/io5";

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;
---

<header class="header pt-6">
  <nav class="navbar container">
    <div class="order-0">
      <Logo />
    </div>
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      id="show-button"
      for="nav-toggle"
      class="order-2 flex cursor-pointer items-center text-black md:order-1 md:hidden"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
    </label>
    <label
      id="hide-button"
      for="nav-toggle"
      class="order-2 hidden cursor-pointer items-center text-black md:order-1"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>
    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full md:order-1 md:flex md:w-auto text-center"
    >
      {
        main.map((menu) => (
          <>
            {menu.hasChildren ? (
              <li class="nav-item nav-dropdown relative cursor-pointer flex flex-col items-center">
                <button 
                  id="dropdown-btn"
                  class="nav-link flex items-center justify-center gap-1 w-auto bg-transparent border-none outline-none cursor-pointer mx-auto"
                  aria-expanded="false"
                >
                  <span>{menu.name}</span>
                  <svg class="h-5 w-5 fill-current transition-transform duration-200" id="dropdown-icon" viewBox="0 0 20 20">
                    <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                  </svg>
                </button>
                <ul 
                  id="dropdown-menu" 
                  class="nav-dropdown-list hidden !block-important position-style bg-white shadow-lg rounded p-2 min-w-[200px] z-50 text-center mx-auto my-2 md:my-0 md:absolute left-1/2 md:-translate-x-1/2 top-full"
                >
                  {menu.children?.map((child) => (
                    <li class="nav-dropdown-item py-2">
                      <a href={child.url} class="nav-dropdown-link block hover:text-primary transition text-center w-full">
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="nav-item flex justify-center">
                <a href={menu.url} class="nav-link block text-center w-full">
                  {menu.name}
                </a>
              </li>
            )}
          </>
        ))
      }
    </ul>
    <div class="order-1 ml-auto flex md:order-2 md:ml-0">
      <a
        class="mr-4 inline-block cursor-pointer p-2 text-xl text-dark transition hover:text-primary md:mr-0"
        href="/search"
        title="search"
        aria-label="search"
      >
        <IoSearch />
      </a>
    </div>
  </nav>
</header>

<style>
  /* පරණ CSS වල තියෙන ඇද හැදීමට වෙනම ස්ටයිල් එකක් */
  .nav-dropdown-list {
    text-align: center !important;
  }
  .nav-dropdown-list a {
    text-align: center !important;
    display: block !important;
  }
  /* මොබයිල් වලදී මැදටම තියාගන්න */
  @media (max-width: 767px) {
    #dropdown-menu {
      width: 90% !important;
      max-width: 250px !important;
      float: none !important;
    }
  }
</style>

<script>
  function initDropdown() {
    const dropdownBtn = document.getElementById("dropdown-btn");
    const dropdownMenu = document.getElementById("dropdown-menu");
    const dropdownIcon = document.getElementById("dropdown-icon");

    if (dropdownBtn && dropdownMenu) {
      dropdownBtn.replaceWith(dropdownBtn.cloneNode(true));
      const newBtn = document.getElementById("dropdown-btn");

      newBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        const isHidden = dropdownMenu.classList.contains("hidden");
        
        if (isHidden) {
          dropdownMenu.classList.remove("hidden");
          dropdownIcon?.classList.add("rotate-180");
          newBtn.setAttribute("aria-expanded", "true");
        } else {
          dropdownMenu.classList.add("hidden");
          dropdownIcon?.classList.remove("rotate-180");
          newBtn.setAttribute("aria-expanded", "false");
        }
      });

      document.addEventListener("click", (e) => {
        if (!newBtn?.contains(e.target as Node) && !dropdownMenu.contains(e.target as Node)) {
          dropdownMenu.classList.add("hidden");
          dropdownIcon?.classList.remove("rotate-180");
          newBtn?.setAttribute("aria-expanded", "false");
        }
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initDropdown);
  document.addEventListener("astro:page-load", initDropdown);
</script>
