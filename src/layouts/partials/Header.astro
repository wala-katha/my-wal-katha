---
import Logo from "@/components/Logo.astro";
import menu from "@/config/menu.json";
import { IoSearch } from "react-icons/io5";

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;
---

{/* 👑 PREMIUM GLOSSY GLASSMORPHISM HEADER */}
<header class="header sticky top-0 z-50 py-4 transition-all duration-300 border-b border-white/[0.06] bg-[#010203]/80 backdrop-blur-md shadow-[0_4px_30px_rgba(0,0,0,0.8)]">
  <nav class="navbar container flex items-center justify-between">
    {/* LOGO */}
    <div class="order-0">
      <Logo />
    </div>

    {/* MOBILE MENU TOGGLE CHECKBOX */}
    <input id="nav-toggle" type="checkbox" class="hidden" />

    {/* 🎯 FIX: CONTRAST FOR MOBILE BUTTONS (text-black වෙනුවට text-white/90 දීලා කැපී පෙනෙන්න හැදුවා) */}
    <label
      id="show-button"
      for="nav-toggle"
      class="order-2 flex cursor-pointer items-center text-white/90 hover:text-[#01AD9F] transition-colors duration-200 md:order-1 md:hidden p-2"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V15z"></path>
      </svg>
    </label>
    
    <label
      id="hide-button"
      for="nav-toggle"
      class="order-2 hidden cursor-pointer items-center text-white/90 hover:text-[#01AD9F] transition-colors duration-200 md:order-1 p-2"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>

    {/* NAVIGATION MENU */}
    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full md:order-1 md:flex md:w-auto text-center gap-1"
    >
      {
        main.map((menu, index) => (
          <>
            {menu.hasChildren ? (
              <li class="nav-item nav-dropdown relative cursor-pointer flex flex-col items-center group">
                <button 
                  class="nav-dropdown-btn nav-link flex items-center justify-center gap-1 w-auto bg-transparent border-none outline-none cursor-pointer mx-auto text-white/80 hover:text-[#01AD9F] font-semibold py-2 px-4 transition duration-200"
                  aria-expanded="false"
                  data-dropdown-target={`dropdown-${index}`}
                >
                  <span>{menu.name}</span>
                  <svg class="h-4 w-4 fill-current transition-transform duration-300 dropdown-icon" viewBox="0 0 20 20">
                    <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                  </svg>
                </button>
                
                {/* 👑 PREMIUM DARK DROPDOWN BOX (bg-white අයින් කර වීදුරු ලුක් එකක් දුන්නා) */}
                <ul 
                  id={`dropdown-${index}`} 
                  class="nav-dropdown-list hidden md:absolute left-1/2 md:-translate-x-1/2 top-full min-w-[220px] rounded-xl border border-white/[0.08] bg-[#0c0d10]/95 backdrop-blur-lg p-2 shadow-[0_10px_30px_rgba(0,0,0,0.5)] z-50 text-center mx-auto my-2 md:my-0"
                >
                  {menu.children?.map((child) => (
                    <li class="py-1.5">
                      <a 
                        href={child.url} 
                        class="block px-4 py-2 text-sm text-white/70 hover:text-[#01AD9F] hover:bg-white/[0.03] rounded-lg transition duration-200 text-center w-full font-medium"
                      >
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li class="nav-item flex justify-center">
                <a 
                  href={menu.url} 
                  class="nav-link block text-center w-full text-white/80 hover:text-[#01AD9F] font-semibold py-2 px-4 transition duration-200"
                >
                  {menu.name}
                </a>
              </li>
            )}
          </>
        ))
      }
    </ul>

    {/* SEARCH ICON BUTTON */}
    <div class="order-1 ml-auto flex md:order-2 md:ml-0">
      <a
        /* 🎯 FIX: text-dark වෙනුවට text-white/80 කරලා හොවර් එකේදී Teal වර්ණයෙන් දිලිසෙන්න හැදුවා */
        class="inline-block cursor-pointer p-2.5 text-xl text-white/80 transition-all duration-300 hover:text-[#01AD9F] hover:scale-110 rounded-xl bg-white/[0.02] hover:bg-white/[0.06] border border-white/[0.05]"
        href="/search"
        title="search"
        aria-label="search"
      >
        <IoSearch />
      </a>
    </div>
  </nav>
</header>

<style is:global>
  /* මෙනු ලින්ක්ස් වල ඇක්ටිව් හෝ හොවර් ස්ටයිල්ස් හරියාකාරව වැඩ කිරීමට */
  .nav-link {
    font-family: inherit;
  }
  
  /* මොබයිල් වලදී මෙනු එක ලස්සනට පෙන්වීමට */
  @media (max-width: 767px) {
    .navbar-nav {
      background-color: #060709 !important;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 1rem;
      padding: 1rem;
      margin-top: 1rem;
      box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }
    .nav-dropdown-list {
      position: relative !important;
      left: 0 !important;
      transform: none !important;
      width: 100% !important;
      background-color: rgba(255, 255, 255, 0.02) !important;
      margin-top: 0.5rem !important;
      border-color: rgba(255, 255, 255, 0.04) !important;
    }
  }
</style>

<script>
  function initDropdowns() {
    // 🎯 FIX: QuerySelectorAll පාවිච්චි කරලා සයිට් එකේ ඩ්‍රොප්ඩවුන් කීයක් තිබ්බත් වැඩ කරන විදිහට හැදුවා
    const dropdownButtons = document.querySelectorAll(".nav-dropdown-btn");

    dropdownButtons.forEach((btn) => {
      // පරණ Listener ක්ලෝන් කරලා අයින් කිරීම (Astro Page Swapping වලදී බග් නොවෙන්න)
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      const targetId = newBtn.getAttribute("data-dropdown-target");
      const menu = document.getElementById(targetId || "");
      const icon = newBtn.querySelector(".dropdown-icon");

      if (newBtn && menu) {
        newBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          
          // වෙනත් ඇරිලා තියෙන ඩ්‍රොප්ඩවුන් වැසීම
          document.querySelectorAll(".nav-dropdown-list").forEach((m) => {
            if (m.id !== targetId) {
              m.classList.add("hidden");
              m.previousElementSibling?.querySelector(".dropdown-icon")?.classList.remove("rotate-180");
              m.previousElementSibling?.setAttribute("aria-expanded", "false");
            }
          });

          const isHidden = menu.classList.contains("hidden");
          if (isHidden) {
            menu.classList.remove("hidden");
            icon?.classList.add("rotate-180");
            newBtn.setAttribute("aria-expanded", "true");
          } else {
            menu.classList.add("hidden");
            icon?.classList.remove("rotate-180");
            newBtn.setAttribute("aria-expanded", "false");
          }
        });
      }
    });

    // පිටත ක්ලික් කරපු ගමන් ඩ්‍රොප්ඩවුන් වැසීම
    document.addEventListener("click", () => {
      document.querySelectorAll(".nav-dropdown-list").forEach((menu) => {
        menu.classList.add("hidden");
        menu.previousElementSibling?.querySelector(".dropdown-icon")?.classList.remove("rotate-180");
        menu.previousElementSibling?.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Astro ස්ක්‍රිප්ට් එක ලයිව් වෙද්දී රන් කිරීම
  document.addEventListener("DOMContentLoaded", initDropdowns);
  document.addEventListener("astro:page-load", initDropdowns);
</script>
