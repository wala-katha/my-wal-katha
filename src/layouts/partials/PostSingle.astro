---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/layouts/components/SimilarPosts.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, authors, categories, image, date, tags } = post.data;

// 🎯 SMART SEO RELATED POSTS LOGIC
let smartSimilarPosts = posts.filter(
  (p) => p.id !== post.id && p.data.categories?.some((cat) => categories?.includes(cat))
);
if (!smartSimilarPosts.length) {
  smartSimilarPosts = posts.filter((p) => p.id !== post.id);
}
const finalSimilarPosts = smartSimilarPosts.slice(0, 6);

// ✅ SAFE: Token frontend එකේ නැහැ — Worker side validate කරනවා
// API_URL only (no secret exposed)
const WORKER_API = "https://comments.wala-katha.workers.dev/api/comments";
---

<section class="section bg-[#010203] relative">
  <div class="container">
    <article class="row justify-center">
      {/* POST TITLE */}
      <div class="md:col-10 text-center">
        <h1 set:html={markdownify(title)} class="h2 text-[#F8F8FF] font-black drop-shadow-md" />

        {/* META INFO ROW */}
        <ul class="mt-4 flex flex-wrap items-center justify-center text-[#F8F8FF]/90">
          <li class="mx-3">
            {allAuthors
              .filter((author) =>
                authors.map((a: string) => slugify(a)).includes(slugify(author.data.title))
              )
              .map((author) => (
                <a
                  href={`/authors/${slugify(author.id)}`}
                  class="flex items-center hover:text-primary font-bold text-[#F8F8FF]"
                >
                  {author.data.image && (
                    <Image
                      src={author.data.image}
                      alt={author.data.title}
                      height={50}
                      width={50}
                      class="mr-2 h-6 w-6 rounded-full border border-white/20"
                    />
                  )}
                  <span>{author.data.title}</span>
                </a>
              ))}
          </li>
          <li class="mx-3 flex items-center flex-wrap font-semibold text-[#F8F8FF]">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-[#01AD9F]" />
            {dateFormat(date)}
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-[#01AD9F]" />
            <ul>
              {categories.map((category: string, i: number) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}`}
                    class="mr-2 hover:text-primary font-bold bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF]"
                  >
                    {humanize(category)}
                    {i !== categories.length - 1 && ","}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {image && (
          <Image
            src={image}
            height={500}
            width={1000}
            alt={title}
            class="rounded-lg w-full h-auto object-cover mx-auto max-w-4xl border border-white/10"
            loading="eager"
          />
        )}
      </div>

      <div class="md:col-10">
        <div class="content mb-16 text-left text-[#F8F8FF] custom-post-content">
          <Content />
        </div>

        {/* TAGS BLOCK */}
        <div class="flex flex-wrap items-center justify-between border-t border-white/10 pt-6">
          <ul class="mr-4 mb-4 space-x-3">
            {tags.map((tag: string) => (
              <li class="inline-block">
                <a
                  href={`/tags/${slugify(tag)}`}
                  class="block rounded-lg bg-[#FFCC00] border border-[#FFCC00] px-4 py-2 font-black text-[#010203] text-sm hover:bg-[#E6B800] transition duration-300"
                >
                  #{humanize(tag)}
                </a>
              </li>
            ))}
          </ul>
          <Share
            className="social-share mb-4 text-[#F8F8FF]"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>

  {/* ================================================================
    💬 FLOATING COMMENT BUTTON
  ================================================================ */}
  <button
    id="comment-floating-btn"
    class="fixed bottom-6 right-6 z-40 flex items-center gap-2 bg-[#01AD9F] text-[#010203] font-black px-5 py-3 rounded-full shadow-[0_4px_20px_rgba(1,173,159,0.4)] hover:bg-[#01c4b4] hover:scale-105 active:scale-95 transition-all duration-300 cursor-pointer select-none"
    aria-label="Open Comments Section"
    aria-expanded="false"
    aria-controls="comment-popup-modal"
  >
    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/>
    </svg>
    <span>කමෙන්ට්ස්</span>
  </button>

  {/* ================================================================
    💬 COMMENT POPUP MODAL
    ✅ SEO: aria-label, role="dialog" correctly set
    ✅ Token frontmatter එකේ නැහැ — data-post-id only
  ================================================================ */}
  <div
    id="comment-popup-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#010203]/70 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="comment-modal-title"
    data-post-id={post.id}
    data-api-url={WORKER_API}
  >
    <div class="relative w-full max-w-2xl bg-[#0c0d10] border border-white/10 rounded-2xl shadow-[0_10px_50px_rgba(0,0,0,0.8)] flex flex-col max-h-[85vh]">
      
      {/* MODAL HEADER */}
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/[0.06]">
        <h3 id="comment-modal-title" class="text-lg font-black text-[#F8F8FF] flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-[#01AD9F] animate-pulse" aria-hidden="true"></span>
          අදහස් සහ කමෙන්ට්ස්
        </h3>
        <button
          id="comment-close-btn"
          class="p-1.5 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.08] text-white/60 hover:text-red-400 transition-colors duration-200 cursor-pointer outline-none"
          aria-label="Close Comments"
        >
          <svg class="w-6 h-6 stroke-current fill-none" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {/* COMMENT SCROLL AREA */}
      <div id="comments-wrapper-area" class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar">
        
        {/* SUBMIT FORM */}
        <div class="mb-4">
          <label for="cf-comment-text" class="block text-xs text-white/50 mb-2 font-semibold uppercase tracking-wider">
            ඔබේ අදහස ලියන්න
          </label>
          <textarea
            id="cf-comment-text"
            class="w-full h-24 p-3 bg-white/5 border border-white/10 rounded-xl text-[#F8F8FF] placeholder-white/30 focus:border-[#01AD9F] outline-none transition duration-200 resize-none text-sm"
            placeholder="ඔබේ කමෙන්ට් එක මෙතන ටයිප් කරන්න..."
            maxlength="1000"
          ></textarea>
          <div class="flex items-center justify-between mt-2">
            <span id="char-count" class="text-xs text-white/30">0 / 1000</span>
            <button
              id="cf-submit-comment"
              class="bg-[#01AD9F] text-[#010203] font-bold px-6 py-2 rounded-xl text-sm transition hover:bg-[#01c4b4] cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Submit Comment
            </button>
          </div>
        </div>

        {/* COMMENTS LIST */}
        <div class="border-t border-white/5 pt-4">
          <p class="text-xs text-white/40 tracking-wider uppercase mb-3 font-semibold">Recent Comments</p>
          <div
            id="comments-list-hook"
            class="space-y-3"
            aria-live="polite"
            aria-label="Comments list"
          >
            <p id="no-comments-msg" class="text-sm text-white/50 italic py-2 text-center">
              කමෙන්ට්ස් ලෝඩ් වෙමින් පවතී...
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

{/* RELATED STORIES */}
{finalSimilarPosts.length > 0 && (
  <section class="section pt-12 pb-16 bg-gradient-to-b from-[#010203] via-[#022c16] to-[#010203] border-t border-white/5">
    <div class="container">
      <h2 class="mb-8 font-black text-center h4 text-[#F8F8FF]">
        ඔබ කැමති විය හැකි තවත් කතා
      </h2>
      <div class="row">
        <SimilarPosts posts={finalSimilarPosts} />
      </div>
    </div>
  </section>
)}

<style is:global>
  .custom-post-content p,
  .custom-post-content span,
  .custom-post-content li,
  .custom-post-content strong,
  .custom-post-content h1,
  .custom-post-content h2,
  .custom-post-content h3,
  .custom-post-content h4 {
    color: #F8F8FF !important;
  }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.1);
    border-radius: 99px;
  }
</style>

<script>
  function initCommentSystem() {
    const floatingBtn = document.getElementById("comment-floating-btn");
    const modal = document.getElementById("comment-popup-modal");
    const closeBtn = document.getElementById("comment-close-btn");
    const submitBtn = document.getElementById("cf-submit-comment") as HTMLButtonElement | null;
    const textarea = document.getElementById("cf-comment-text") as HTMLTextAreaElement | null;
    const commentsListHook = document.getElementById("comments-list-hook");
    const noCommentsMsg = document.getElementById("no-comments-msg");
    const charCount = document.getElementById("char-count");

    // ✅ Token නැහැ — API URL සහ postId HTML data attributes වලින් ගන්නවා
    const postId = modal?.getAttribute("data-post-id") ?? "";
    const API_URL = modal?.getAttribute("data-api-url") ?? "";

    // Character counter
    textarea?.addEventListener("input", () => {
      const len = textarea.value.length;
      if (charCount) charCount.textContent = `${len} / 1000`;
    });

    // ✅ XSS-safe comment card render
    function renderCommentCard(content: string, dateStr: string, prepend = false) {
      if (!commentsListHook) return;
      const card = document.createElement("div");
      card.className = "p-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-left shadow-sm";

      const header = document.createElement("div");
      header.className = "flex items-center justify-between mb-1.5";

      const name = document.createElement("span");
      name.className = "text-xs font-bold text-[#01AD9F]";
      name.textContent = "Anonymous Reader"; // textContent = XSS safe

      const dateEl = document.createElement("span");
      dateEl.className = "text-[11px] text-white/30";
      dateEl.textContent = dateStr; // textContent = XSS safe

      header.appendChild(name);
      header.appendChild(dateEl);

      const body = document.createElement("p");
      body.className = "text-sm text-white/80 leading-relaxed";
      body.textContent = content; // ✅ textContent — XSS inject කරන්න බැහැ

      card.appendChild(header);
      card.appendChild(body);

      if (prepend && commentsListHook.firstChild) {
        commentsListHook.insertBefore(card, commentsListHook.firstChild);
      } else {
        commentsListHook.appendChild(card);
      }
    }

    // Fetch comments
    async function loadComments() {
      if (!commentsListHook || !postId || !API_URL) return;
      if (noCommentsMsg) noCommentsMsg.textContent = "කමෙන්ට්ස් ලෝඩ් වෙමින් පවතී...";

      try {
        const res = await fetch(`${API_URL}?postId=${encodeURIComponent(postId)}`);

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const comments: Array<{ content: string; date?: string; created_at?: string }> = await res.json();

        if (comments.length > 0) {
          if (noCommentsMsg) noCommentsMsg.style.display = "none";
          // Clear existing (except noCommentsMsg)
          Array.from(commentsListHook.children).forEach((child) => {
            if (child.id !== "no-comments-msg") child.remove();
          });
          comments.forEach((c) => renderCommentCard(c.content, c.date ?? c.created_at ?? ""));
        } else {
          if (noCommentsMsg) {
            noCommentsMsg.style.display = "";
            noCommentsMsg.textContent = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
          }
        }
      } catch (err) {
        console.error("Comments fetch error:", err);
        if (noCommentsMsg) {
          noCommentsMsg.style.display = "";
          noCommentsMsg.textContent = "කමෙන්ට්ස් ලෝඩ් කිරීමට අසමත් වුණා. නැවත උත්සාහ කරන්න.";
        }
      }
    }

    // Modal open/close
    function openModal() {
      if (!modal || !floatingBtn) return;
      modal.classList.remove("hidden");
      requestAnimationFrame(() => {
        modal.classList.remove("opacity-0", "pointer-events-none");
      });
      floatingBtn.setAttribute("aria-expanded", "true");
      loadComments();
    }

    function closeModal() {
      if (!modal || !floatingBtn) return;
      modal.classList.add("opacity-0", "pointer-events-none");
      floatingBtn.setAttribute("aria-expanded", "false");
      setTimeout(() => modal.classList.add("hidden"), 300);
    }

    floatingBtn?.addEventListener("click", (e) => { e.stopPropagation(); openModal(); });
    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

    // Keyboard: Escape closes modal
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) closeModal();
    });

    // Submit comment
    submitBtn?.addEventListener("click", async () => {
      const content = textarea?.value.trim() ?? "";
      if (!content) {
        alert("කරුණාකර හිස් කමෙන්ට් ඉදිරිපත් කිරීමෙන් වලකින්න!");
        return;
      }
      if (content.length > 1000) {
        alert("කමෙන්ට් එක අකුරු 1000 ට වඩා දිගු විය නොහැකිය.");
        return;
      }

      submitBtn.textContent = "Submitting...";
      submitBtn.disabled = true;

      const dateStr = new Date().toLocaleDateString("en-US", {
        year: "numeric", month: "short", day: "numeric",
      });

      try {
        const res = await fetch(API_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ postId, content, date: dateStr }),
        });

        if (res.ok) {
          if (noCommentsMsg) noCommentsMsg.style.display = "none";
          renderCommentCard(content, dateStr, true); // prepend = newest first
          if (textarea) textarea.value = "";
          if (charCount) charCount.textContent = "0 / 1000";
        } else {
          const err = await res.json().catch(() => ({})) as { error?: string };
          alert(err.error ?? "කමෙන්ට් එක ඉදිරිපත් කිරීමට නොහැකි වුණා. නැවත උත්සාහ කරන්න.");
        }
      } catch (err) {
        console.error("Submit error:", err);
        alert("ජාල දෝෂයක් ඇති විය. ඔබේ ආනබන්ධනය පරීක්ෂා කරන්න.");
      } finally {
        submitBtn.textContent = "Submit Comment";
        submitBtn.disabled = false;
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initCommentSystem);
  document.addEventListener("astro:page-load", initCommentSystem);
</script>
