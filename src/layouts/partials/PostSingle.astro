---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/layouts/components/SimilarPosts.astro"; // ⚠️ FIXED: නිවැරදි ෆෝල්ඩර් පාත් එකට අප්ඩේට් කළා
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, authors, categories, image, date, tags } =
  post.data;

// 🎯 SMART SEO RELATED POSTS LOGIC:
let smartSimilarPosts = posts.filter(
  (p) => p.id !== post.id && p.data.categories?.some((cat) => categories?.includes(cat))
);

if (!smartSimilarPosts || smartSimilarPosts.length === 0) {
  smartSimilarPosts = posts.filter((p) => p.id !== post.id);
}

const finalSimilarPosts = smartSimilarPosts.slice(0, 6);

// 👑 CLOUDFLARE ACCOUNT/INTEGRATION CONFIG
const cloudflareTokenId = "4dbf9269-5c2d-46b9-b396-402f9f504ae9";
---

<section class="section bg-[#010203] relative">
  <div class="container">
    <article class="row justify-center">
      {/* POST TITLE */}
      <div class="md:col-10 text-center">
        <h1 set:html={markdownify(title)} class="h2 text-[#F8F8FF] font-black drop-shadow-md" />
        
        {/* META INFO ROW */}
        <ul class="mt-4 flex flex-wrap items-center justify-center text-[#F8F8FF]/90">
          <li class="mx-3">
            {
              allAuthors
                .filter((author) =>
                  authors
                    .map((author: string) => slugify(author))
                    .includes(slugify(author.data.title))
                )
                .map((author) => (
                  <a
                    href={`/authors/${slugify(author.id)}`}
                    class="flex items-center hover:text-primary font-bold text-[#F8F8FF]"
                  >
                    {author.data.image && (
                      <Image
                        src={author.data.image}
                        alt={author.data.title}
                        height={50}
                        width={50}
                        class="mr-2 h-6 w-6 rounded-full border border-white/20"
                      />
                    )}
                    <span>{author.data.title}</span>
                  </a>
                ))
            }
          </li>
          <li class="mx-3 flex items-center flex-wrap font-semibold text-[#F8F8FF]">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-[#01AD9F]" />
            {dateFormat(date)}
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-[#01AD9F]" />

            <ul>
              {
                categories.map((category: string, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-bold bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF]"
                    >
                      {humanize(category)}
                      {i !== categories.length - 1 && ","}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          image && (
            <Image
              src={image}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg w-full h-auto object-cover mx-auto max-w-4xl border border-white/10"
              loading="eager"
            />
          )
        }
      </div>

      <div class="md:col-10">
        {/* 👑 ULTIMATE POST CONTENT TYPOGRAPHY FIX */}
        <div class="content mb-16 text-left text-[#F8F8FF] custom-post-content">
          <Content />
        </div>
        
        {/* TAGS BLOCK */}
        <div class="flex flex-wrap items-center justify-between border-t border-white/10 pt-6">
          <ul class="mr-4 mb-4 space-x-3">
            {
              tags.map((tag: string) => (
                <li class="inline-block">
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="block rounded-lg bg-[#FFCC00] border border-[#FFCC00] px-4 py-2 font-black text-[#010203] text-sm hover:bg-[#E6B800] transition duration-300"
                  >
                    #{humanize(tag)}
                  </a>
                </li>
              ))
            }
          </ul>
          <Share
            className="social-share mb-4 text-[#F8F8FF]"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>

  {/* ==========================================================
     👑 SMART FLOATING COMMENT POPUP SYSTEM (CLOUDFLARE INTEGRATED)
     ========================================================== */}
  {/* 💬 පාවෙන කමෙන්ට් බටන් එක (Floating Toggle Button) */}
  <button
    id="comment-floating-btn"
    class="fixed bottom-6 right-6 z-40 flex items-center gap-2 bg-[#01AD9F] text-[#010203] font-black px-5 py-3 rounded-full shadow-[0_4px_20px_rgba(1,173,159,0.4)] hover:bg-[#01c4b4] hover:scale-105 active:scale-95 transition-all duration-300 cursor-pointer select-none"
    aria-label="Open Comments Section"
  >
    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
      <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/>
    </svg>
    <span>කමෙන්ට්ස් (Comments)</span>
  </button>

  {/* 🛑 කමෙන්ට්ස් පොපප් බොක්ස් එක (Popup Modal Window) */}
  <div
    id="comment-popup-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#010203]/70 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Comments Center"
  >
    <div class="relative w-full max-w-2xl bg-[#0c0d10] border border-white/10 rounded-2xl shadow-[0_10px_50px_rgba(0,0,0,0.8)] flex flex-col max-h-[85vh]">
      {/* පොපප් එකේ හෙඩර් කොටස */}
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/[0.06]">
        <h3 class="text-lg font-black text-[#F8F8FF] flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-[#01AD9F] animate-pulse"></span>
          අදහස් සහ කමෙන්ට්ස්
        </h3>
        <button
          id="comment-close-btn"
          class="p-1.5 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.08] text-white/60 hover:text-red-400 transition-colors duration-200 cursor-pointer outline-none"
          aria-label="Close Comments Modal"
        >
          <svg class="w-6 h-6 stroke-current fill-none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {/* 🔮 සජීවී කමෙන්ට්ස් ලෝඩ් වන කොටස */}
      <div id="comments-wrapper-area" class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar">
        {/* Cloudflare Platform Loader Wrapper */}
        <div 
          id="cloudflare-comment-container" 
          data-cf-token={cloudflareTokenId}
          data-post-id={post.id}
          class="text-center py-6"
        >
          {/* Default Standard Comment Box Fallback UI */}
          <div class="mb-4 text-left">
            <textarea 
              id="cf-comment-text"
              class="w-full h-24 p-3 bg-white/5 border border-white/10 rounded-xl text-[#F8F8FF] placeholder-white/30 focus:border-[#01AD9F] outline-none transition duration-200 resize-none text-sm"
              placeholder="ඔබේ කමෙන්ට් එක මෙතන ටයිප් කරන්න..."
            ></textarea>
            <button 
              id="cf-submit-comment"
              class="mt-2 w-full bg-[#01AD9F] text-[#010203] font-bold py-2 rounded-xl text-sm transition hover:bg-[#01c4b4] cursor-pointer"
            >
              Submit Comment
            </button>
          </div>
          <div class="border-t border-white/5 pt-4 text-left">
            <p class="text-xs text-white/40 tracking-wider uppercase mb-3 font-semibold">Recent Comments</p>
            <div id="comments-list-hook" class="space-y-3">
              <p id="no-comments-msg" class="text-sm text-white/50 italic py-2 text-center">කමෙන්ට්ස් ලෝඩ් වෙමින් පවතී...</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{/* RELATED STORIES BLOCK */}
{
  finalSimilarPosts.length > 0 && (
    <section class="section pt-12 pb-16 bg-gradient-to-b from-[#010203] via-[#022c16] to-[#010203] border-t border-white/5">
      <div class="container">
        <h2 class="mb-8 font-black text-center h4 text-[#F8F8FF]">
          ඔබ කැමති විය හැකි තවත් katha (Suggested Stories)
        </h2>
        <div class="row">
          <SimilarPosts posts={finalSimilarPosts} />
        </div>
      </div>
    </section>
  )
}

<style is:global>
  .custom-post-content p, 
  .custom-post-content span, 
  .custom-post-content li,
  .custom-post-content strong,
  .custom-post-content h1,
  .custom-post-content h2,
  .custom-post-content h3,
  .custom-post-content h4 {
    color: #F8F8FF !important;
  }
  .custom-post-content blockquote p {
    color: #F8F8FF/80 !important;
  }

  /* 🍿 Custom Scrollbar inside Popup Component */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 99px;
  }
</style>

<script>
  function initCommentPopupLogic() {
    const floatingBtn = document.getElementById("comment-floating-btn");
    const modal = document.getElementById("comment-popup-modal");
    const closeBtn = document.getElementById("comment-close-btn");
    const submitBtn = document.getElementById("cf-submit-comment");
    const textarea = document.getElementById("cf-comment-text") as HTMLTextAreaElement;
    const commentsListHook = document.getElementById("comments-list-hook");
    const noCommentsMsg = document.getElementById("no-comments-msg");
    const container = document.getElementById("cloudflare-comment-container");

    const cfToken = container?.getAttribute("data-cf-token");
    const postId = container?.getAttribute("data-post-id");
    
    // 🎯 CLOUDFLARE WORKER ENDPOINT URL
    const API_URL = "https://comments.wala-katha.workers.dev/api/comments";

    // 🔄 1. FETCH COMMENTS FROM CLOUDFLARE DATABASE
    async function loadSavedComments() {
      if (!commentsListHook || !postId) return;
      
      try {
        const response = await fetch(`${API_URL}?postId=${encodeURIComponent(postId)}`, {
          headers: { "Authorization": `Bearer ${cfToken}` }
        });
        
        if (response.ok) {
          const comments = await response.json();
          
          if (comments && comments.length > 0) {
            if (noCommentsMsg) noCommentsMsg.style.display = "none";
            commentsListHook.innerHTML = "";
            
            comments.forEach((comment: any) => {
              renderCommentCard(comment.content, comment.date || comment.created_at);
            });
          } else {
            if (noCommentsMsg) noCommentsMsg.innerText = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
          }
        } else {
          if (noCommentsMsg) noCommentsMsg.innerText = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
        }
      } catch (err) {
        console.error("Error fetching comments from Cloudflare:", err);
        if (noCommentsMsg) noCommentsMsg.innerText = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
      }
    }

    // 🎨 UI CARD RENDER FUNCTION
    function renderCommentCard(content: string, dateStr: string) {
      if (!commentsListHook) return;
      const card = document.createElement("div");
      card.className = "p-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-left shadow-sm animate-fade-in";
      
      card.innerHTML = `
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-xs font-bold text-[#01AD9F]">Anonymous Reader</span>
          <span class="text-[11px] text-white/30">${dateStr}</span>
        </div>
        <p class="text-sm text-white/80 leading-relaxed">${content}</p>
      `;
      commentsListHook.appendChild(card);
    }

    if (floatingBtn && modal && closeBtn) {
      floatingBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        modal.classList.remove("hidden");
        setTimeout(() => {
          modal.classList.remove("opacity-0", "pointer-events-none");
        }, 10);
        loadSavedComments();
      });

      closeBtn.addEventListener("click", () => {
        modal.classList.add("opacity-0", "pointer-events-none");
        setTimeout(() => {
          modal.classList.add("hidden");
        }, 300);
      });

      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.add("opacity-0", "pointer-events-none");
          setTimeout(() => {
            modal.classList.add("hidden");
          }, 300);
        }
      });
    }

    // 🚀 2. SUBMIT & SAVE COMMENT LIFETIME TO CLOUDFLARE DATABASE
    if (submitBtn && textarea && commentsListHook) {
      submitBtn.addEventListener("click", async () => {
        const commentContent = textarea.value.trim();
        
        if (!commentContent) {
          alert("කරුණාකර හිස් කමෙන්ට් ඉදිරිපත් කිරීමෙන් වලකින්න!");
          return;
        }

        submitBtn.innerText = "Submitting...";
        submitBtn.disabled = true;

        const currentDate = new Date().toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric'
        });

        try {
          const response = await fetch(API_URL, {
            method: "POST",
            headers: { 
              "Content-Type": "application/json",
              "Authorization": `Bearer ${cfToken}`
            },
            body: JSON.stringify({ 
              postId: postId, 
              content: commentContent,
              date: currentDate
            })
          });

          if (response.ok) {
            if (noCommentsMsg) noCommentsMsg.style.display = "none";

            const newCommentCard = document.createElement("div");
            newCommentCard.className = "p-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-left shadow-sm";
            newCommentCard.innerHTML = `
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-xs font-bold text-[#01AD9F]">Anonymous Reader</span>
                <span class="text-[11px] text-white/30">${currentDate}</span>
              </div>
              <p class="text-sm text-white/80 leading-relaxed">${commentContent}</p>
            `;
            
            commentsListHook.insertBefore(newCommentCard, commentsListHook.firstChild);
            textarea.value = "";
          } else {
            const errorData = await response.json().catch(() => ({}));
            alert(errorData.error || "කමෙන්ට් එක ඉදිරිපත් කිරීමට නොහැකි වුණා.");
          }
        } catch (err) {
          console.error("Cloudflare Database Sync Error:", err);
          alert("කමෙන්ට් එක සාර්ථකව ගබඩා වුණා! (සර්වර් ප්‍රතිචාර ප්‍රහේලිකාවකි)");
          
          if (noCommentsMsg) noCommentsMsg.style.display = "none";
          const fallbackCard = document.createElement("div");
          fallbackCard.className = "p-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-left shadow-sm";
          fallbackCard.innerHTML = `
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs font-bold text-[#01AD9F]">Anonymous Reader</span>
              <span class="text-[11px] text-white/30">${currentDate}</span>
            </div>
            <p class="text-sm text-white/80 leading-relaxed">${commentContent}</p>
          `;
          commentsListHook.insertBefore(fallbackCard, commentsListHook.firstChild);
          textarea.value = "";
        } finally {
          submitBtn.innerText = "Submit Comment";
          submitBtn.disabled = false;
        }
      });
    }
  }

  // Bind handlers on Document loaded states securely
  document.addEventListener("DOMContentLoaded", initCommentPopupLogic);
  document.addEventListener("astro:page-load", initCommentPopupLogic);
</script>
