## ⚠️ Worker script එකත් update කළ යුතුයි

Edit සහ Delete support කරන්න Worker code එකට **PATCH** සහ **DELETE** methods add කළ යුතුයි. Worker editor එකේ ඇති code replace කරන්න:

```javascript
const CORS_HEADERS = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Methods": "GET, POST, PATCH, DELETE, OPTIONS",
  "Access-Control-Allow-Headers": "Content-Type",
};

export default {
  async fetch(request, env) {
    if (request.method === "OPTIONS") {
      return new Response(null, { status: 204, headers: CORS_HEADERS });
    }

    const url = new URL(request.url);
    const path = url.pathname;

    if (request.method === "GET" && path === "/") {
      return Response.json({ status: "ok", service: "wala-katha comments API" }, { headers: CORS_HEADERS });
    }

    if (request.method === "GET" && path === "/api/comments") {
      const postId = url.searchParams.get("postId");
      if (!postId) return Response.json({ error: "postId required" }, { status: 400, headers: CORS_HEADERS });
      try {
        const stored = await env.COMMENTS_KV.get(`comments:${postId}`);
        return Response.json(stored ? JSON.parse(stored) : [], { headers: CORS_HEADERS });
      } catch {
        return Response.json({ error: "Failed to load" }, { status: 500, headers: CORS_HEADERS });
      }
    }

    if (request.method === "POST" && path === "/api/comments") {
      let body;
      try { body = await request.json(); } catch {
        return Response.json({ error: "Invalid JSON" }, { status: 400, headers: CORS_HEADERS });
      }
      const { postId, content, date } = body;
      if (!postId || !content?.trim()) return Response.json({ error: "postId සහ content අවශ්‍යයි" }, { status: 400, headers: CORS_HEADERS });
      if (content.length > 1000) return Response.json({ error: "දිග වැඩිය (max 1000)" }, { status: 400, headers: CORS_HEADERS });
      const forbidden = /<script|javascript:|on\w+=/i;
      if (forbidden.test(content)) return Response.json({ error: "Invalid content" }, { status: 400, headers: CORS_HEADERS });
      try {
        const stored = await env.COMMENTS_KV.get(`comments:${postId}`);
        const comments = stored ? JSON.parse(stored) : [];
        comments.unshift({
          content: content.trim(),
          date: date ?? new Date().toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }),
          created_at: new Date().toISOString(),
        });
        if (comments.length > 100) comments.splice(100);
        await env.COMMENTS_KV.put(`comments:${postId}`, JSON.stringify(comments));
        // ✅ Return index (0 = newest, unshift කළ නිසා)
        return Response.json({ success: true, index: 0 }, { headers: CORS_HEADERS });
      } catch {
        return Response.json({ error: "Save failed" }, { status: 500, headers: CORS_HEADERS });
      }
    }

    // ✅ PATCH — Edit comment
    if (request.method === "PATCH" && path === "/api/comments") {
      let body;
      try { body = await request.json(); } catch {
        return Response.json({ error: "Invalid JSON" }, { status: 400, headers: CORS_HEADERS });
      }
      const { postId, index, content } = body;
      if (!postId || index === undefined || !content?.trim()) {
        return Response.json({ error: "postId, index, content අවශ්‍යයි" }, { status: 400, headers: CORS_HEADERS });
      }
      try {
        const stored = await env.COMMENTS_KV.get(`comments:${postId}`);
        const comments = stored ? JSON.parse(stored) : [];
        if (index < 0 || index >= comments.length) return Response.json({ error: "Invalid index" }, { status: 400, headers: CORS_HEADERS });
        comments[index].content = content.trim();
        comments[index].edited = true;
        await env.COMMENTS_KV.put(`comments:${postId}`, JSON.stringify(comments));
        return Response.json({ success: true }, { headers: CORS_HEADERS });
      } catch {
        return Response.json({ error: "Edit failed" }, { status: 500, headers: CORS_HEADERS });
      }
    }

    // ✅ DELETE — Delete comment
    if (request.method === "DELETE" && path === "/api/comments") {
      const postId = url.searchParams.get("postId");
      const index = parseInt(url.searchParams.get("index") ?? "-1");
      if (!postId || index < 0) return Response.json({ error: "postId සහ index අවශ්‍යයි" }, { status: 400, headers: CORS_HEADERS });
      try {
        const stored = await env.COMMENTS_KV.get(`comments:${postId}`);
        const comments = stored ? JSON.parse(stored) : [];
        if (index >= comments.length) return Response.json({ error: "Invalid index" }, { status: 400, headers: CORS_HEADERS });
        comments.splice(index, 1);
        await env.COMMENTS_KV.put(`comments:${postId}`, JSON.stringify(comments));
        return Response.json({ success: true }, { headers: CORS_HEADERS });
      } catch {
        return Response.json({ error: "Delete failed" }, { status: 500, headers: CORS_HEADERS });
      }
    }

    return Response.json({ error: "Not found" }, { status: 404, headers: CORS_HEADERS });
  },
};
