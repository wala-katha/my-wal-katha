---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/layouts/components/SimilarPosts.astro"; // ⚠️ FIXED: නිවැරදි ෆෝල්ඩර් පාත් එකට අප්ඩේට් කළා
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, authors, categories, image, date, tags } =
  post.data;

// 🎯 SMART SEO RELATED POSTS LOGIC:
// 1. දැනට කියවන පෝස්ට් එක අයින් කර සමාන කැටගරි තියෙන පෝස්ට් පෙරීම
let smartSimilarPosts = posts.filter(
  (p) => p.id !== post.id && p.data.categories?.some((cat) => categories?.includes(cat))
);

// 2. ⚡ SEO FALLBACK: සමාන කැටගරි නැත්නම්, සයිට් එකේ තියෙන වෙනත් ඕනෑම පෝස්ට් ඔටෝ අරන් පෙන්වීම
if (!smartSimilarPosts || smartSimilarPosts.length === 0) {
  smartSimilarPosts = posts.filter((p) => p.id !== post.id);
}

// 3. FIX: කෙළින් අතට (2:3) ලස්සනට පේළියට වාඩි වෙන්න පෝස්ට් ප්‍රමාණය 6ක් දක්වා වැඩි කළා
const finalSimilarPosts = smartSimilarPosts.slice(0, 6);
---

<section class="section">
  <div class="container">
    <article class="row justify-center">
      <div class="md:col-10 text-center">
        {/* ⚡ MAXIMUM PURE WHITE MAIN TITLE */}
        <h1 set:html={markdownify(title)} class="h2 text-white font-black" />
        
        {/* ⚡ METADATA ROW FIX: අයිකන සහ ලින්ක්ස් සියල්ල පට්ට සුදු පාට කළා */}
        <ul class="mt-4 flex flex-wrap items-center justify-center text-white font-bold">
          <li class="mx-3">
            {
              allAuthors
                .filter((author) =>
                  authors
                    .map((author: string) => slugify(author))
                    .includes(slugify(author.data.title))
                )
                .map((author) => (
                  <a
                    href={`/authors/${slugify(author.id)}`}
                    class="flex items-center hover:text-primary font-bold text-white"
                  >
                    {author.data.image && (
                      <Image
                        src={author.data.image}
                        alt={author.data.title}
                        height={50}
                        width={50}
                        class="mr-2 h-6 w-6 rounded-full"
                      />
                    )}
                    <span class="text-white">{author.data.title}</span>
                  </a>
                ))
            }
          </li>
          <li class="mx-3 flex items-center flex-wrap font-bold text-white">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-white" />
            {dateFormat(date)}
          </li>
          <li class="mx-3 flex items-center flex-wrap text-white">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-white" />

            <ul>
              {
                categories.map((category: string, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-bold text-white"
                    >
                      {humanize(category)}
                      {i !== categories.length - 1 && ","}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          image && (
            <Image
              src={image}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg w-full h-auto object-cover mx-auto max-w-4xl border border-white/10"
              loading="eager"
            />
          )
        }
      </div>

      <div class="md:col-10">
        {/* 👑 MAXIMUM PROSE CONTENT FIX: 
            ලිපිය ඇතුළත තියෙන සියලුම Markdown/HTML අකුරු (p, h1, h2, h3, li, strong) 
            කලු පසුබිම උඩ පට්ටම සුදු පාටින් දිලිසෙන්න 'prose-invert text-white' සහ custom css එකතු කළා */}
        <div class="content mb-16 text-left text-white prose prose-invert max-w-full post-body-content">
          <Content />
        </div>
        
        <div class="flex flex-wrap items-center justify-between">
          <ul class="mr-4 mb-4 space-x-3">
            {
              tags.map((tag: string) => (
                <li class="inline-block mb-2">
                  {/* ⚡ MAXIMUM DARK TAGS WITH PURE WHITE TEXT */}
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="block rounded-lg bg-[#010203] border border-white/40 px-4 py-2 font-black text-white text-sm hover:border-white hover:text-primary transition duration-300"
                  >
                    #{humanize(tag)}
                  </a>
                </li>
              ))
            }
          </ul>
          <Share
            className="social-share mb-4 text-white"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>
</section>

{
  finalSimilarPosts.length > 0 && (
    <section class="section pt-0">
      <div class="container">
        {/* ⚡ SUGGESTED TITLE MAXIMUM PURE WHITE FIX */}
        <h2 class="mb-8 font-black text-left h4 border-l-4 border-primary pl-3 text-white">
          ඔබ කැමති විය හැකි තවත් කතා (Suggested Stories)
        </h2>
        
        <div class="row">
          <SimilarPosts posts={finalSimilarPosts} />
        </div>
      </div>
    </section>
  )
}

{/* ⚡ INLINE INJECT FORCED CSS: 
    Tailwind මඟින් සමහරවිට Override නොවන Markdown අකුරු (p, span, li) සියල්ල බලහත්කාරයෙන්ම More Maximum White කිරීමට */}
<style is:global>
  .post-body-content p, 
  .post-body-content span, 
  .post-body-content li, 
  .post-body-content strong,
  .post-body-content h1,
  .post-body-content h2,
  .post-body-content h3,
  .post-body-content h4 {
    color: #ffffff !important;
    font-weight: 600 !important; /* කියවීම පහසු කිරීමට අකුරු දශමයක් මහත කළා */
  }
</style>
