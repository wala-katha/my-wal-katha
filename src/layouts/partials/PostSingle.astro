
---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/layouts/components/SimilarPosts.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, authors, categories, image, date, tags } = post.data;

// 🎯 SMART SEO RELATED POSTS LOGIC
let smartSimilarPosts = posts.filter(
  (p) => p.id !== post.id && p.data.categories?.some((cat) => categories?.includes(cat))
);
if (!smartSimilarPosts.length) {
  smartSimilarPosts = posts.filter((p) => p.id !== post.id);
}
const finalSimilarPosts = smartSimilarPosts.slice(0, 6);

// ✅ SAFE: Token frontend එකේ නැහැ — Worker side validate කරනවා
const WORKER_API = "https://comments.wala-katha.workers.dev/api/comments";
---

<section class="section bg-[#010203] relative">
  <div class="container">
    <article class="row justify-center">
      {/* POST TITLE */}
      <div class="md:col-10 text-center">
        <h1 set:html={markdownify(title)} class="h2 text-[#F8F8FF] font-black drop-shadow-md" />

        {/* META INFO ROW */}
        <ul class="mt-4 flex flex-wrap items-center justify-center text-[#F8F8FF]/90">
          <li class="mx-3">
            {allAuthors
              .filter((author) =>
                authors.map((a: string) => slugify(a)).includes(slugify(author.data.title))
              )
              .map((author) => (
                <a
                  href={`/authors/${slugify(author.id)}`}
                  class="flex items-center hover:text-primary font-bold text-[#F8F8FF]"
                >
                  {author.data.image && (
                    <Image
                      src={author.data.image}
                      alt={author.data.title}
                      height={50}
                      width={50}
                      class="mr-2 h-6 w-6 rounded-full border border-white/20"
                    />
                  )}
                  <span>{author.data.title}</span>
                </a>
              ))}
          </li>
          <li class="mx-3 flex items-center flex-wrap font-semibold text-[#F8F8FF]">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-[#01AD9F]" />
            {dateFormat(date)}
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-[#01AD9F]" />
            <ul>
              {categories.map((category: string, i: number) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}`}
                    class="mr-2 hover:text-primary font-bold bg-white/10 px-2 py-0.5 rounded text-[#F8F8FF]"
                  >
                    {humanize(category)}
                    {i !== categories.length - 1 && ","}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {image && (
          <Image
            src={image}
            height={500}
            width={1000}
            alt={title}
            class="rounded-lg w-full h-auto object-cover mx-auto max-w-4xl border border-white/10"
            loading="eager"
          />
        )}
      </div>

      <div class="md:col-10">
        <div class="content mb-16 text-left text-[#F8F8FF] custom-post-content">
          <Content />
        </div>

        {/* TAGS BLOCK */}
        <div class="flex flex-wrap items-center justify-between border-t border-white/10 pt-6">
          <ul class="mr-4 mb-4 space-x-3">
            {tags.map((tag: string) => (
              <li class="inline-block">
                <a
                  href={`/tags/${slugify(tag)}`}
                  class="block rounded-lg bg-[#FFCC00] border border-[#FFCC00] px-4 py-2 font-black text-[#010203] text-sm hover:bg-[#E6B800] transition duration-300"
                >
                  #{humanize(tag)}
                </a>
              </li>
            ))}
          </ul>
          <Share
            className="social-share mb-4 text-[#F8F8FF]"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>

  {/* ================================================================
    💬 FLOATING COMMENT BUTTON — ANIMATED
  ================================================================ */}
  <button
    id="comment-floating-btn"
    class="fixed bottom-6 right-6 z-40 flex items-center gap-2 bg-[#01AD9F] text-[#010203] font-black px-5 py-3 rounded-full shadow-[0_4px_20px_rgba(1,173,159,0.4)] cursor-pointer select-none comment-float-btn"
    aria-label="Open Comments Section"
    aria-expanded="false"
    aria-controls="comment-popup-modal"
  >
    <span class="comment-btn-ring"></span>
    <svg class="w-5 h-5 fill-current relative z-10" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/>
    </svg>
    <span class="relative z-10">කමෙන්ට්ස්</span>
  </button>

  {/* ================================================================
    💬 COMMENT POPUP MODAL
  ================================================================ */}
  <div
    id="comment-popup-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#010203]/70 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="comment-modal-title"
    data-post-id={post.id}
    data-api-url={WORKER_API}
  >
    <div class="relative w-full max-w-2xl bg-[#0c0d10] border border-white/10 rounded-2xl shadow-[0_10px_50px_rgba(0,0,0,0.8)] flex flex-col max-h-[85vh]">

      {/* MODAL HEADER */}
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/[0.06]">
        <h3 id="comment-modal-title" class="text-lg font-black text-[#F8F8FF] flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-[#01AD9F] animate-pulse" aria-hidden="true"></span>
          අදහස් සහ කමෙන්ට්ස්
        </h3>
        <button
          id="comment-close-btn"
          class="p-1.5 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.08] text-white/60 hover:text-red-400 transition-colors duration-200 cursor-pointer outline-none"
          aria-label="Close Comments"
        >
          <svg class="w-6 h-6 stroke-current fill-none" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {/* COMMENT SCROLL AREA */}
      <div id="comments-wrapper-area" class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar">

        {/* SUBMIT FORM */}
        <div class="mb-4">
          <label for="cf-comment-text" class="block text-xs text-white/50 mb-2 font-semibold uppercase tracking-wider">
            ඔබේ අදහස ලියන්න
          </label>
          <div class="relative">
            <textarea
              id="cf-comment-text"
              class="w-full h-24 p-3 pr-10 bg-white/5 border border-white/10 rounded-xl text-[#F8F8FF] placeholder-white/30 focus:border-[#01AD9F] outline-none transition duration-200 resize-none text-sm"
              placeholder="ඔබේ කමෙන්ට් එක මෙතන ටයිප් කරන්න..."
              maxlength="1000"
            ></textarea>
            <button
              id="cf-clear-btn"
              class="absolute top-2 right-2 p-1 rounded-lg text-white/20 hover:text-red-400 hover:bg-white/5 transition-colors duration-200 hidden"
              aria-label="Clear comment text"
              type="button"
            >
              <svg class="w-4 h-4 stroke-current fill-none" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="flex items-center justify-between mt-2">
            <span id="char-count" class="text-xs text-white/30">0 / 1000</span>
            <button
              id="cf-submit-comment"
              class="bg-[#01AD9F] text-[#010203] font-bold px-6 py-2 rounded-xl text-sm transition hover:bg-[#01c4b4] cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Submit Comment
            </button>
          </div>
        </div>

        {/* INLINE VALIDATION MESSAGE */}
        <p id="cf-validation-msg" class="hidden text-xs font-semibold px-3 py-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 mb-2"></p>

        {/* COMMENTS LIST */}
        <div class="border-t border-white/5 pt-4">
          <p class="text-xs text-white/40 tracking-wider uppercase mb-3 font-semibold">Recent Comments</p>
          <div
            id="comments-list-hook"
            class="space-y-3"
            aria-live="polite"
            aria-label="Comments list"
          >
            <p id="no-comments-msg" class="text-sm text-white/50 italic py-2 text-center">
              කමෙන්ට්ස් ලෝඩ් වෙමින් පවතී...
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>

  {/* ================================================================
    ✅ SUCCESS TOAST
  ================================================================ */}
  <div
    id="comment-success-toast"
    class="fixed bottom-24 right-6 z-50 flex items-center gap-3 bg-[#01AD9F] text-[#010203] font-bold px-5 py-3 rounded-2xl shadow-[0_4px_24px_rgba(1,173,159,0.5)] translate-y-4 opacity-0 pointer-events-none transition-all duration-300"
    aria-live="polite"
  >
    <svg class="w-5 h-5 fill-current shrink-0" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
    </svg>
    <span>ස්තූතියි! ඔබේ අදහස සාර්ථකව දැමුණා 🙏</span>
  </div>

  {/* ================================================================
    ✏️ EDIT MODAL
  ================================================================ */}
  <div
    id="edit-comment-modal"
    class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-[#010203]/80 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="edit-modal-title"
  >
    <div class="w-full max-w-md bg-[#0c0d10] border border-white/10 rounded-2xl shadow-[0_10px_50px_rgba(0,0,0,0.9)] p-6">
      <h3 id="edit-modal-title" class="text-base font-black text-[#F8F8FF] mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 fill-current text-[#01AD9F]" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
        </svg>
        කමෙන්ට් එක සංස්කරණය කරන්න
      </h3>
      <textarea
        id="edit-comment-textarea"
        class="w-full h-28 p-3 bg-white/5 border border-white/10 rounded-xl text-[#F8F8FF] placeholder-white/30 focus:border-[#01AD9F] outline-none transition duration-200 resize-none text-sm mb-3"
        placeholder="ඔබේ සංස්කරණය ලියන්න..."
        maxlength="1000"
      ></textarea>
      <div class="flex gap-3 justify-end">
        <button
          id="edit-cancel-btn"
          class="px-4 py-2 rounded-xl text-sm font-bold text-white/50 hover:text-white/80 border border-white/10 hover:border-white/20 transition-colors duration-200 cursor-pointer"
        >
          අවලංගු කරන්න
        </button>
        <button
          id="edit-save-btn"
          class="px-5 py-2 rounded-xl text-sm font-bold bg-[#01AD9F] text-[#010203] hover:bg-[#01c4b4] transition-colors duration-200 cursor-pointer disabled:opacity-50"
        >
          සුරකින්න
        </button>
      </div>
    </div>
  </div>

  {/* ================================================================
    🗑️ DELETE CONFIRM MODAL
  ================================================================ */}
  <div
    id="delete-confirm-modal"
    class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-[#010203]/80 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="delete-modal-title"
  >
    <div class="w-full max-w-sm bg-[#0c0d10] border border-white/10 rounded-2xl shadow-[0_10px_50px_rgba(0,0,0,0.9)] p-6 text-center">
      <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 fill-current text-red-400" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
        </svg>
      </div>
      <h3 id="delete-modal-title" class="text-base font-black text-[#F8F8FF] mb-2">කමෙන්ට් එක මකන්නද?</h3>
      <p class="text-sm text-white/50 mb-5">මෙය ස්ථිරවම මකා දමනු ලැබේ. පසුව නැවත ගත නොහැකිය.</p>
      <div class="flex gap-3 justify-center">
        <button
          id="delete-cancel-btn"
          class="px-4 py-2 rounded-xl text-sm font-bold text-white/50 hover:text-white/80 border border-white/10 hover:border-white/20 transition-colors duration-200 cursor-pointer"
        >
          නැහැ, තබා ගන්න
        </button>
        <button
          id="delete-confirm-btn"
          class="px-5 py-2 rounded-xl text-sm font-bold bg-red-500 text-white hover:bg-red-600 transition-colors duration-200 cursor-pointer"
        >
          ඔව්, මකන්න
        </button>
      </div>
    </div>
  </div>
</section>

{/* RELATED STORIES */}
{finalSimilarPosts.length > 0 && (
  <section class="section pt-12 pb-16 bg-gradient-to-b from-[#010203] via-[#022c16] to-[#010203] border-t border-white/5">
    <div class="container">
      <h2 class="mb-8 font-black text-center h4 text-[#F8F8FF]">
        ඔබ කැමති විය හැකි තවත් කතා
      </h2>
      <div class="row">
        <SimilarPosts posts={finalSimilarPosts} />
      </div>
    </div>
  </section>
)}

<style is:global>
  .custom-post-content p,
  .custom-post-content span,
  .custom-post-content li,
  .custom-post-content strong,
  .custom-post-content h1,
  .custom-post-content h2,
  .custom-post-content h3,
  .custom-post-content h4 {
    color: #F8F8FF !important;
  }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.1);
    border-radius: 99px;
  }

  /* 💬 FLOATING BUTTON ANIMATION */
  .comment-float-btn {
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    animation: cfloat 3s ease-in-out infinite;
  }
  .comment-float-btn:hover {
    transform: scale(1.08) translateY(-2px);
    box-shadow: 0 8px 32px rgba(1,173,159,0.55);
  }
  .comment-float-btn:active {
    transform: scale(0.95);
  }
  @keyframes cfloat {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-6px); }
  }
  .comment-btn-ring {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: rgba(1,173,159,0.35);
    animation: cring 2s ease-out infinite;
    z-index: 0;
  }
  @keyframes cring {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(1.6); opacity: 0; }
  }
</style>

<script>
  // ✅ ROOT FIX: Global init guard — දෙවරක් init වීම සම්පූර්ණයෙන් වළකිනවා
  if (!(window as any).__commentSystemInit) {
    (window as any).__commentSystemInit = true;

    // ✅ Session token — browser session එකේ පමණක් valid
    // මෙම session එකේ ඇති user දැමූ comments පමණක් edit/delete කළ හැකිය
    function getSessionToken(): string {
      let token = sessionStorage.getItem("wk-session-token");
      if (!token) {
        token = `${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;
        sessionStorage.setItem("wk-session-token", token);
      }
      return token;
    }

    const SESSION_TOKEN = getSessionToken();

    function initCommentSystem() {
      const floatingBtn = document.getElementById("comment-floating-btn");
      const modal = document.getElementById("comment-popup-modal");
      const closeBtn = document.getElementById("comment-close-btn");
      const submitBtn = document.getElementById("cf-submit-comment") as HTMLButtonElement | null;
      const textarea = document.getElementById("cf-comment-text") as HTMLTextAreaElement | null;
      const clearBtn = document.getElementById("cf-clear-btn") as HTMLButtonElement | null;
      const commentsListHook = document.getElementById("comments-list-hook");
      const noCommentsMsg = document.getElementById("no-comments-msg");
      const charCount = document.getElementById("char-count");
      const validationMsg = document.getElementById("cf-validation-msg");
      const successToast = document.getElementById("comment-success-toast");

      const editModal = document.getElementById("edit-comment-modal");
      const editTextarea = document.getElementById("edit-comment-textarea") as HTMLTextAreaElement | null;
      const editSaveBtn = document.getElementById("edit-save-btn") as HTMLButtonElement | null;
      const editCancelBtn = document.getElementById("edit-cancel-btn");

      const deleteModal = document.getElementById("delete-confirm-modal");
      const deleteCancelBtn = document.getElementById("delete-cancel-btn");
      const deleteConfirmBtn = document.getElementById("delete-confirm-btn") as HTMLButtonElement | null;

      const postId = modal?.getAttribute("data-post-id") ?? "";
      const API_URL = modal?.getAttribute("data-api-url") ?? "";

      const linkRegex = /https?:\/\/|www\.|\.com|\.lk|\.net|\.org|\.io/i;

      // In-memory list — { id, content, date, ownerToken }
      // ownerToken: මෙම session එකේ user දැමූ comments පමණක් edit/delete කළ හැකිය
      let commentsList: Array<{ id: string; content: string; date: string; ownerToken: string }> = [];
      let activeCommentId: string | null = null;

      // ── HELPERS ────────────────────────────────────────────────

      function generateId(): string {
        return `${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;
      }

      function showValidation(msg: string) {
        if (!validationMsg) return;
        validationMsg.textContent = msg;
        validationMsg.classList.remove("hidden");
        setTimeout(() => validationMsg.classList.add("hidden"), 4000);
      }

      function showSuccessToast() {
        if (!successToast) return;
        successToast.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
        successToast.classList.add("opacity-100", "translate-y-0");
        setTimeout(() => {
          successToast.classList.add("opacity-0", "translate-y-4");
          successToast.classList.remove("opacity-100", "translate-y-0");
        }, 3000);
      }

      // ── CLEAR BUTTON ──────────────────────────────────────────

      textarea?.addEventListener("input", () => {
        const len = textarea.value.length;
        if (charCount) charCount.textContent = `${len} / 1000`;
        if (clearBtn) {
          if (len > 0) clearBtn.classList.remove("hidden");
          else clearBtn.classList.add("hidden");
        }
      });

      clearBtn?.addEventListener("click", () => {
        if (textarea) textarea.value = "";
        if (charCount) charCount.textContent = "0 / 1000";
        clearBtn.classList.add("hidden");
        textarea?.focus();
      });

      // ── RENDER COMMENT CARD ────────────────────────────────────
      // ✅ ownerToken match වූ විට පමණක් edit/delete buttons පෙන්වනවා

      function renderCommentCard(
        id: string,
        content: string,
        dateStr: string,
        ownerToken: string,
        prepend = false
      ) {
        if (!commentsListHook) return;

        const card = document.createElement("div");
        card.className = "p-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-left shadow-sm";
        card.setAttribute("data-comment-id", id);

        const header = document.createElement("div");
        header.className = "flex items-center justify-between mb-1.5";

        const name = document.createElement("span");
        name.className = "text-xs font-bold text-[#01AD9F]";
        name.textContent = "Anonymous Reader";

        const metaRight = document.createElement("div");
        metaRight.className = "flex items-center gap-2";

        const dateEl = document.createElement("span");
        dateEl.className = "text-[11px] text-white/30";
        dateEl.textContent = dateStr;

        metaRight.appendChild(dateEl);

        // ✅ Edit/Delete buttons — තමන්ගේ comment පමණක්
        if (ownerToken === SESSION_TOKEN) {
          const editBtn = document.createElement("button");
          editBtn.className = "p-1 rounded-lg text-white/25 hover:text-[#01AD9F] hover:bg-white/5 transition-colors duration-200 cursor-pointer";
          editBtn.setAttribute("aria-label", "Edit comment");
          editBtn.setAttribute("type", "button");
          editBtn.innerHTML = `<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>`;
          editBtn.addEventListener("click", () => openEditModal(id, content));

          const delBtn = document.createElement("button");
          delBtn.className = "p-1 rounded-lg text-white/25 hover:text-red-400 hover:bg-white/5 transition-colors duration-200 cursor-pointer";
          delBtn.setAttribute("aria-label", "Delete comment");
          delBtn.setAttribute("type", "button");
          delBtn.innerHTML = `<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>`;
          delBtn.addEventListener("click", () => openDeleteModal(id));

          metaRight.appendChild(editBtn);
          metaRight.appendChild(delBtn);
        }

        header.appendChild(name);
        header.appendChild(metaRight);

        const body = document.createElement("p");
        body.className = "text-sm text-white/80 leading-relaxed";
        body.setAttribute("data-comment-body", id);
        body.textContent = content;

        card.appendChild(header);
        card.appendChild(body);

        if (prepend && commentsListHook.firstChild) {
          commentsListHook.insertBefore(card, commentsListHook.firstChild);
        } else {
          commentsListHook.appendChild(card);
        }
      }

      // ── LOAD COMMENTS ──────────────────────────────────────────

      async function loadComments() {
        if (!commentsListHook || !postId || !API_URL) return;
        if (noCommentsMsg) {
          noCommentsMsg.style.display = "";
          noCommentsMsg.textContent = "කමෙන්ට්ස් ලෝඩ් වෙමින් පවතී...";
        }
        Array.from(commentsListHook.children).forEach((child) => {
          if ((child as HTMLElement).id !== "no-comments-msg") child.remove();
        });
        commentsList = [];

        try {
          const res = await fetch(`${API_URL}?postId=${encodeURIComponent(postId)}`);
          if (!res.ok) throw new Error(`HTTP ${res.status}`);

          const comments: Array<{ content: string; date?: string; created_at?: string }> = await res.json();

          if (comments.length > 0) {
            if (noCommentsMsg) noCommentsMsg.style.display = "none";
            comments.forEach((c) => {
              const id = generateId();
              const dateStr = c.date ?? c.created_at ?? "";
              // ✅ Server comments: ownerToken = "" — edit/delete buttons නොපෙනෙයි
              commentsList.push({ id, content: c.content, date: dateStr, ownerToken: "" });
              renderCommentCard(id, c.content, dateStr, "");
            });
          } else {
            if (noCommentsMsg) {
              noCommentsMsg.style.display = "";
              noCommentsMsg.textContent = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
            }
          }
        } catch (err) {
          console.error("Comments fetch error:", err);
          if (noCommentsMsg) {
            noCommentsMsg.style.display = "";
            noCommentsMsg.textContent = "කමෙන්ට්ස් ලෝඩ් කිරීමට අසමත් වුණා. නැවත උත්සාහ කරන්න.";
          }
        }
      }

      // ── MODAL OPEN/CLOSE ────────────────────────────────────────

      function openModal() {
        if (!modal || !floatingBtn) return;
        modal.classList.remove("hidden");
        requestAnimationFrame(() => modal.classList.remove("opacity-0", "pointer-events-none"));
        floatingBtn.setAttribute("aria-expanded", "true");
        loadComments();
      }

      function closeModal() {
        if (!modal || !floatingBtn) return;
        modal.classList.add("opacity-0", "pointer-events-none");
        floatingBtn.setAttribute("aria-expanded", "false");
        setTimeout(() => modal.classList.add("hidden"), 300);
      }

      floatingBtn?.addEventListener("click", (e) => { e.stopPropagation(); openModal(); });
      closeBtn?.addEventListener("click", closeModal);
      modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          if (editModal && !editModal.classList.contains("hidden")) closeEditModal();
          else if (deleteModal && !deleteModal.classList.contains("hidden")) closeDeleteModal();
          else if (modal && !modal.classList.contains("hidden")) closeModal();
        }
      });

      // ── SUBMIT COMMENT ──────────────────────────────────────────
      // ✅ isSubmitting flag — rapid double-click නිසා duplicate වීම වළකිනවා

      let isSubmitting = false;

      submitBtn?.addEventListener("click", async () => {
        if (isSubmitting) return;

        const content = textarea?.value.trim() ?? "";

        if (!content) {
          showValidation("⚠️ හිස් අදහස් පල කරන්න බැහැ. කරුණාකර ඔබේ අදහස ලියන්න!");
          textarea?.focus();
          return;
        }
        if (linkRegex.test(content)) {
          showValidation("🔗 ලින්ක් දැමීමට අවසර නැහැ. කරුණාකර ලින්ක් ඉවත් කර ඔබේ අදහස දක්වන්න.");
          textarea?.focus();
          return;
        }
        if (content.length > 1000) {
          showValidation("⚠️ කමෙන්ට් එක අකුරු 1000 ට වඩා දිගු විය නොහැකිය.");
          return;
        }

        isSubmitting = true;
        submitBtn.textContent = "Submitting...";
        submitBtn.disabled = true;

        const dateStr = new Date().toLocaleDateString("en-US", {
          year: "numeric", month: "short", day: "numeric",
        });

        try {
          const res = await fetch(API_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ postId, content, date: dateStr }),
          });

          if (res.ok) {
            if (noCommentsMsg) noCommentsMsg.style.display = "none";
            const newId = generateId();
            // ✅ ownerToken = SESSION_TOKEN — මෙම user ට පමණක් edit/delete පෙනෙයි
            commentsList.unshift({ id: newId, content, date: dateStr, ownerToken: SESSION_TOKEN });
            renderCommentCard(newId, content, dateStr, SESSION_TOKEN, true);
            if (textarea) textarea.value = "";
            if (charCount) charCount.textContent = "0 / 1000";
            if (clearBtn) clearBtn.classList.add("hidden");
            if (validationMsg) validationMsg.classList.add("hidden");
            showSuccessToast();
          } else {
            const err = await res.json().catch(() => ({})) as { error?: string };
            showValidation(err.error ?? "කමෙන්ට් එක ඉදිරිපත් කිරීමට නොහැකි වුණා. නැවත උත්සාහ කරන්න.");
          }
        } catch (err) {
          console.error("Submit error:", err);
          showValidation("ජාල දෝෂයක් ඇති විය. ඔබේ සම්බන්ධතාව පරීක්ෂා කරන්න.");
        } finally {
          isSubmitting = false;
          submitBtn.textContent = "Submit Comment";
          submitBtn.disabled = false;
        }
      });

      // ── EDIT ────────────────────────────────────────────────────

      function openEditModal(id: string, currentContent: string) {
        if (!editModal || !editTextarea) return;
        activeCommentId = id;
        editTextarea.value = currentContent;
        editModal.classList.remove("hidden");
        requestAnimationFrame(() => editModal.classList.remove("opacity-0", "pointer-events-none"));
        editTextarea.focus();
      }

      function closeEditModal() {
        if (!editModal) return;
        editModal.classList.add("opacity-0", "pointer-events-none");
        setTimeout(() => editModal.classList.add("hidden"), 300);
        activeCommentId = null;
      }

      editCancelBtn?.addEventListener("click", closeEditModal);
      editModal?.addEventListener("click", (e) => { if (e.target === editModal) closeEditModal(); });

      editSaveBtn?.addEventListener("click", () => {
        if (!activeCommentId || !editTextarea) return;
        const newContent = editTextarea.value.trim();
        if (!newContent) return;

        const entry = commentsList.find((c) => c.id === activeCommentId);
        // ✅ Double-check: තමන්ගේ comment පමණක් update කරනවා
        if (entry && entry.ownerToken === SESSION_TOKEN) {
          entry.content = newContent;
          const bodyEl = commentsListHook?.querySelector(`[data-comment-body="${activeCommentId}"]`);
          if (bodyEl) bodyEl.textContent = newContent;
        }

        closeEditModal();
      });

      // ── DELETE ──────────────────────────────────────────────────

      function openDeleteModal(id: string) {
        if (!deleteModal) return;
        activeCommentId = id;
        deleteModal.classList.remove("hidden");
        requestAnimationFrame(() => deleteModal.classList.remove("opacity-0", "pointer-events-none"));
      }

      function closeDeleteModal() {
        if (!deleteModal) return;
        deleteModal.classList.add("opacity-0", "pointer-events-none");
        setTimeout(() => deleteModal.classList.add("hidden"), 300);
        activeCommentId = null;
      }

      deleteCancelBtn?.addEventListener("click", closeDeleteModal);
      deleteModal?.addEventListener("click", (e) => { if (e.target === deleteModal) closeDeleteModal(); });

      deleteConfirmBtn?.addEventListener("click", () => {
        if (!activeCommentId || !commentsListHook) return;

        const entry = commentsList.find((c) => c.id === activeCommentId);
        // ✅ Double-check: තමන්ගේ comment පමණක් delete කරනවා
        if (!entry || entry.ownerToken !== SESSION_TOKEN) {
          closeDeleteModal();
          return;
        }

        commentsList = commentsList.filter((c) => c.id !== activeCommentId);
        const card = commentsListHook.querySelector(`[data-comment-id="${activeCommentId}"]`);
        if (card) card.remove();

        if (commentsList.length === 0 && noCommentsMsg) {
          noCommentsMsg.style.display = "";
          noCommentsMsg.textContent = "තවම කමෙන්ට්ස් කිසිවක් නැත. පළමුවැන්නා වන්න!";
        }

        closeDeleteModal();
      });
    }

    // ✅ එකම event listener එකක් පමණක් — duplicate init නැහැ
    document.addEventListener("astro:page-load", initCommentSystem);
    // First page load සඳහා (astro:page-load fire නොවෙන අවස්ථා)
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCommentSystem);
    } else {
      initCommentSystem();
    }
  }
</script>
